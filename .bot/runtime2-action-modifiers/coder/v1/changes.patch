+{
+    [IsNotNull]
+    public partial Data.@this<int> Ms { get; init; }
+
+    public async Task<global::App.Data.@this> Run()
+    {
+        await Task.Delay(Ms.Value, Context.CancellationToken);
+        return global::App.Data.@this.Ok();
+    }
+}
