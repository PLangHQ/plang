+namespace PLang.Tests.App.Modules.modifier;
+
+/// <summary>
+/// Tests for the timeout.after modifier handler.
+/// Wraps an action with a CancellationTokenSource that fires after Ms milliseconds.
+/// </summary>
+public class TimeoutAfterTests
+{
+    private global::App.@this _app = null!;
+    private global::App.Actor.Context.@this Ctx => _app.Context;
+
+    [Before(Test)]
+    public void Setup()
+    {
+        _app = new global::App.@this("/app");
+    }
+
+    [After(Test)]
+    public async Task Cleanup() => await _app.DisposeAsync();
+
+    [Test]
+    public async Task After_ActionCompletesBefore_PassesThroughResult()
+    {
+        // Action finishes in 10ms, timeout is 5000ms -> result passes through
+        await Assert.That(true).IsFalse(); // Assert.Fail("Not implemented")
+    }
+
+    [Test]
+    public async Task After_ActionExceedsTimeout_Returns408Error()
+    {
+        // Action takes 5000ms, timeout is 50ms -> returns ServiceError with 408 status
+        await Assert.That(true).IsFalse(); // Assert.Fail("Not implemented")
+    }
+
+    [Test]
+    public async Task After_CancellationTokenPropagatedToAction()
+    {
+        // Verify context.PushCancellation is called so the action can observe the timeout token
+        await Assert.That(true).IsFalse(); // Assert.Fail("Not implemented")
+    }
+
+    [Test]
+    public async Task After_ParentCancellation_PropagatesException()
+    {
+        // Parent token cancelled (not timeout) -> OperationCanceledException propagates,
+        // not caught as timeout error
+        await Assert.That(true).IsFalse(); // Assert.Fail("Not implemented")
+    }
+
+    [Test]
+    public async Task After_ZeroMsTimeout_ImmediateTimeout()
+    {
+        // Ms = 0 -> action should timeout immediately
+        await Assert.That(true).IsFalse(); // Assert.Fail("Not implemented")
+    }
+
+    [Test]
+    public async Task After_NestedWithOtherModifiers_TimeoutWrapsOuter()
+    {
+        // timeout(order=1) wraps cache(order=2) wraps action
+        // If cache lookup takes too long, timeout still fires
+        await Assert.That(true).IsFalse(); // Assert.Fail("Not implemented")
+    }
+}
