+                        pendingComment.Append(closePart);
+                    }
+                    inBlockComment = false;
+                }
+                else
+                {
+                    if (pendingComment.Length > 0) pendingComment.Append('\n');
+                    pendingComment.Append(raw.Trim());
+                }
