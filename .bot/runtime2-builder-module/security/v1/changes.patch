+				if (defaultAttr.Length == 0) continue;
+				var attr = (PLang.Runtime2.modules.DefaultAttribute)defaultAttr[0];
+				defaults.Add(new PLang.Runtime2.Engine.Memory.Data(prop.Name.ToLowerInvariant(), attr.Value));
+			}
+			return defaults;
+		}
