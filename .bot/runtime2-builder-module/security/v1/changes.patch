+        name.Equals("Content-Encoding", StringComparison.OrdinalIgnoreCase) ||
+        name.Equals("Content-Language", StringComparison.OrdinalIgnoreCase) ||
+        name.Equals("Content-Disposition", StringComparison.OrdinalIgnoreCase) ||
