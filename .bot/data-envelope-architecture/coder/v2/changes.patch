-
-    // Deserialize back to Data (the next layer)
-    return Serializer.Deserialize<Data>(decryptedBytes);
-}
-
-
-// === Decompress() ===
-
-public Data Decompress()
-{
-    if (!string.Equals(this.Type.Value, "archived", StringComparison.OrdinalIgnoreCase))
