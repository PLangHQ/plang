-
-
-// === Step 2: Compress() ===
-// Compresses if the content is compressible, no-op otherwise
-
-private static readonly HashSet<string> NotCompressible = 
-    new(StringComparer.OrdinalIgnoreCase) { "image", "video", "audio", "archive" };
-
-public Data Compress()
-{
