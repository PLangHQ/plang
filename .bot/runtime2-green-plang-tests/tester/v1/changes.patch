AD|OPTIONS|QUERY) = GET]), Body([object?]), Headers([dict\u003Cstring,object\u003E?]), ContentType([string = \u0022application/json\u0022]), Encoding([string = \u0022utf-8\u0022]), TimeoutInSec([int = 30]), Unsigned([bool = false]), SignOptions([sign?]), OnStream([goal.call?]), StreamAs([streamformat?(Line|SSE|Bytes)])\n- http.download [no-cache] Url([string]), SaveTo([string]), IfExists([fileexists(Error|Overwrite|Skip) = Error]), Headers([dict\u003Cstring,object\u003E?]), TimeoutInSec([int = 30]), Unsigned([bool = false]), SignOptions([sign?]), OnProgress([goal.call?])\n- http.upload [no-cache] Url([string]), Content([object]), Method([httpmethod(GET|POST|PUT|DELETE|PATCH|HEAD|OPTIONS|QUERY) = POST]), Headers([dict\u003Cstring,object\u003E?]), Encoding([string = \u0022utf-8\u0022]), TimeoutInSec([int = 30]), Unsigned([bool = false]), SignOptions([sign?]), As([contentas?(File|Base64|Form|Text)]), OnProgress([goal.call?])\n- http.configure [no-cache] TimeoutInSec([int?]), BaseUrl([string?]), DefaultHeaders([dict\u003Cstring,object\u003E?]), ContentType([string?]), Encoding([string?]), Unsigned([bool?]), FollowRedirects([bool?]), MaxRedirects([int?]), Default([bool = false])\n\n- file.delete [no-cache] Path([path]), IgnoreIfNotFound([bool = false]), Recursive([bool = false])\n- file.copy [no-cache] Source([path]), Destination([path]), Overwrite([bool = false]), IncludeSubfolders([bool = true])\n- file.read Path([path]), ResolveVariables([bool = false])\n- file.exists Path([path])\n- file.save [no-cache] Path([path]), Value([object?])\n- file.list Path([path]), Pattern([string = \u0022*\u0022]), Recursive([bool = false])\n- file.move [no-cache] Source([path]), Destination([path]), Overwrite([bool = false])\n\n- builder.types (no parameters)\n- builder.validateResponse StepResults([object]), Goal([object])\n- builder.app Path([string = \u0022.\u0022])\n- builder.actions (no parameters)\n- builder.validate Actions([this?])\n- builder.goalsSave Goal([this])\n- builder.go