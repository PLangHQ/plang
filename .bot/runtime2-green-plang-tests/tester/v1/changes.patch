his])\n- builder.promoteGroups Steps([object])\n- builder.appSave (no parameters)\n\n- timer.end [no-cache] Name([string?]), Static([concurrentdictionary])\n- timer.start [no-cache] Name([string?]), Scope([string = \u0022goal\u0022]), Static([concurrentdictionary])\n- timer.sleep [no-cache] Ms([int])\n\n- error.throw [no-cache] Message([string]), StatusCode([int = 500]), Key([string?])\n- error.handle [no-cache] StatusCode([int?]), Key([string?]), Message([string?]), Goal([goal.call?]), RetryCount([int?]), RetryOverMs([int?]), Order([errororder?(GoalFirst|RetryFirst)]), IgnoreError([bool = false])\n\n- signing.sign [no-cache] Data([object?]), Contracts([list\u003Cstring\u003E?]), Headers([dict\u003Cstring,object\u003E?]), ExpiresInMs([int?])\n- signing.verify [no-cache] Data([object?]), Contracts([list\u003Cstring\u003E?]), Headers([dict\u003Cstring,object\u003E?]), TimeoutMs([long?])\n\n- event.remove [no-cache] EventId([string])\n- event.skipAction [no-cache] Value([object])\n- event.on [no-cache] Type([string]), GoalToCall([goal.call]), GoalPattern([string?]), StepPattern([string?]), ActionPattern([string?]), IsRegex([bool = false]), Priority([int = 0]), Actor([this?(user|service|system)])\n\n- identity.get Name([string?])\n- identity.unarchive [no-cache] Name([string])\n- identity.setDefault [no-cache] Name([string])\n- identity.export Name([string?])\n- identity.create [no-cache] Name([string = \u0022default\u0022]), SetAsDefault([bool = false]), Provider([string?])\n- identity.list (no parameters)\n- identity.rename [no-cache] Name([string]), NewName([string])\n- identity.archive [no-cache] Name([string]), Force([bool = false])\n\n- assert.lessThan A([object?]), B([object?]), Message([string?])\n- assert.isFalse Value([object?]), Message([string?])\n- assert.greaterThan A([object?]), B([object?]), Message([string?])\n- assert.notEquals Expected([object?]), Actual([object?]), Message([string?])\n- assert.isTrue Value([object?]), Message([string?])\n- assert.isN