@@ -0,0 +1,22 @@
+Start
+/ Test: sign with explicit provider param overrides settings default
+/ Note: at PLang level we only have ed25519 (no DLL loading), so this exercises
+/ the provider param → resolution path. C# tests cover real swap with mocks.
+/ We test two things: (1) explicit provider param works, (2) algorithm field reflects it.
+- create identity testSigner
+- set %data1% = { "payload": "default" }
+- sign %data1%
+- assert %data1.Signature.Algorithm% equals 'ed25519', "default provider should be ed25519"
+/ Now sign with explicit provider param — same provider but exercises the override path
+- set %data2% = { "payload": "explicit" }
+- sign %data2%, provider ed25519
+- verify %data2% with contracts ['C0'], write to %verifyResult%
+- assert %verifyResult.Success% is true, "explicit provider param should verify"
+- assert %data2.Signature.Algorithm% equals 'ed25519', "algorithm should reflect provider used"
+/ Test that setting a non-existent provider fails
+- set %data3% = { "payload": "bad" }
+- sign %data3%, provider nonexistent-algo, on error call HandleBadProvider
+- assert %badProvider% is true, "non-existent provider should fail"
+
+HandleBadProvider
+- set %badProvider% = true
