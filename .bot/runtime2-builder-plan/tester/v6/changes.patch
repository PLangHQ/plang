+    border-radius: 8px;
+    overflow: hidden;
+  }
+  .buildgoal-llm-title {
+    padding: 10px 16px;
+    background: var(--surface);
+    font-size: 13px;
+    font-weight: 600;
+    cursor: pointer;
+    display: flex;
+    justify-content: space-between;
+    align-items: center;
+    user-select: none;
+  }
+  .buildgoal-llm-title:hover { background: var(--surface2); }
+  .buildgoal-llm-body { display: none; }
+  .buildgoal-llm-body.open { display: block; }
+
+  /* Step cards */
+  .step-card {
+    margin-bottom: 12px;
+    border: 1px solid var(--border);
+    border-radius: 8px;
+    overflow: hidden;
+    transition: border-color 0.2s;
+  }
+  .step-card.has-error { border-color: rgba(233,69,96,0.4); }
+  .step-card.has-detail { border-color: rgba(91,155,213,0.3); }
+
+  .step-header {
+    padding: 12px 16px;
+    background: var(--surface);
+    display: flex;
+    align-items: flex-start;
+    gap: 10px;
+    cursor: pointer;
+    user-select: none;
+  }
+  .step-header:hover { background: var(--surface2); }
+  .step-index {
+    font-size: 11px;
+    font-weight: 700;
+    color: var(--text-dim);
+    background: rgba(255,255,255,0.05);
+    padding: 2px 8px;
+    border-radius: 4px;
+    flex-shrink: 0;
+    margin-top: 1px;
+  }
+  .step-text {
+    flex: 1;
+    font-size: 13px;
+    font-family: 'Cascadia Code', 'Fira Code', 'Consolas', monospace;
+    line-height: 1.5;
+    word-break: break-word;
+  }
+  .step-status {
+    flex-shrink: 0;
+    display: flex;
+    gap: 4px;
+    align-items: center;
+    margin-top: 1px;
+  }
+
+  /* Flow pipeline */
+  .step-flow {
+    padding: 0 16px 12px 50px;
+    background: var(--surface);
+    display: flex;
+    flex-wrap: wrap;
+    gap: 0;
+    align-items: center;
+    font-size: 11px;
+  }
+  .flow-phase {
+    display: inline-flex;
+    align-items: center;
+    gap: 4px;
+    padding: 3px 8px;
+    border-radius: 4px;
+    margin: 2px 0;
+  }
+  .flow-arrow {
+    color: var(--text-dim);
+    margin: 0 2px;
+    font-size: 10px;
+  }
+  .flow-phase.phase-pass { background: rgba(78,204,163,0.1); color: var(--green); }
+  .flow-phase.phase-error { background: rgba(233,69,96,0.15); color: var(--accent); cursor: pointer; }
+  .flow-phase.phase-detail { background: rgba(91,155,213,0.15); color: var(--blue); cursor: pointer; }
+  .flow-phase.phase-neutral { background: rgba(255,255,255,0.05); color: var(--text-dim); }
+  .flow-phase.phase-medium { background: rgba(240,192,64,0.12); color: var(--yellow); }
+
+  /* Step detail body (expandable) */
+  .step-body { display: none; }
+  .step-body.open { display: block; }
+
+  /* Error detail */
+  .error-detail {
+    padding: 10px 16px 10px 50px;
+    background: rgba(233,69,96,0.05);
+    border-top: 1px solid var(--border);
+    font-size: 12px;
+    color: var(--accent);
+    font-family: 'Cascadia Code', 'Fira Code', 'Consolas', monospace;
+  }
+
+  /* Prompt/Response blocks */
+  .prompt-section {
+    border-top: 1px solid var(--border);
+    margin: 0 16px 12px 34px;
+    border-radius: 6px;
+    overflow: hidden;
+    border: 1px solid var(--border);
+  }
+  .prompt-section-title {
+    padding: 8px 12px;
+    font-size: 12px;
+    font-weight: 600;
+    color: var(--blue);
+    background: rgba(91,155,213,0.05);
+    display: flex;
+    justify-content: space-between;
+    align-items: center;
+  }
+
+  .block {
+    border-top: 1px solid var(--border);
+  }
+  .block-label {
+    padding: 6px 12px;
+    font-size: 11px;
+    font-weight: 600;
+    text-transform: uppercase;
+    color: var(--text-dim);
+    background: rgba(0,0,0,0.2);
+    cursor: pointer;
+    display: flex;
+    justify-content: space-between;
+    align-items: center;
+  }
+  .block-label:hover { color: var(--text); }
+  .block-content {
+    display: none;
+    max-height: 600px;
+    overflow: auto;
+    padding: 12px;
+    background: rgba(0,0,0,0.3);
+  }
+  .block-content.open { display: block; }
+  pre {
+    font-family: 'Cascadia Code', 'Fira Code', 'Consolas', monospace;
+    font-size: 12px;
+    line-height: 1.5;
+    white-space: pre-wrap;
+    word-break: break-word;
+  }
+
+  /* Actions summary */
+  .actions-summary {
+    padding: 8px 16px 8px 50px;
+    background: rgba(0,0,0,0.1);
+    font-size: 12px;
+    font-family: 'Cascadia Code', 'Fira Code', 'Consolas', monospace;
+    border-top: 1px solid var(--border);
+  }
+  .action-line {
+    color: var(--green);
+    padding: 2px 0;
+  }
+  .action-line .param-name { color: var(--text-dim); }
+  .action-line .param-value { color: var(--text); }
+  .action-line .param-type { color: var(--yellow); font-size: 10px; }
+  .modifier-line {
+    color: var(--orange);
+    font-size: 11px;
+    padding: 2px 0 2px 16px;
+  }
+</style>
+</head>
+<body>
+
+<div id="sidebar">
+  <header>
+    <span>Builder Trace</span>
+    <div class="meta" id="build-meta">waiting for build data...</div>
+  </header>
+  <div id="goal-list"></div>
+  <div id="controls">
+    <input type="checkbox" id="auto-refresh" checked>
+    <label for="auto-refresh">Auto-refresh (3s)</label>
+  </div>
+</div>
+
+<div id="main" class="empty">
+  <span>Select a goal or waiting for build data...</span>
+</div>
+
+<script>
+const params = new URLSearchParams(location.search);
+const TRACE_BASE = params.get('traces') || '/.build/traces';
+const POLL_MS = 3000;
+
+let buildRun = null;
+let lastHash = null;
+let selectedGoalIndex = null;
+
+function hashStr(s) {
+  let h = 0;
+  for (let i = 0; i < s.length; i++) h = ((h << 5) - h + s.charCodeAt(i)) | 0;
+  return h.toString(36);
+}
+
+function esc(s) {
+  if (!s) return '';
+  const d = document.createElement('div');
+  d.textContent = String(s);
+  return d.innerHTML;
+}
+
+function sizeLabel(val) {
+  const s = typeof val === 'string' ? val : JSON.stringify(val);
+  const b = new Blob([s]).size;
+  return b < 1024 ? b + 'B' : (b / 1024).toFixed(1) + 'KB';
+}
+
+// ---------- Data fetching ----------
+
+async function poll() {
+  try {
+    // Try API first (dynamic server), fall back to build-run.json (static)
+    let goals = [];
+    const apiR = await fetch('/api/traces', { cache: 'no-store' }).catch(() => null);
+    if (apiR?.ok) {
+      const files = await apiR.json();
+      const traces = await Promise.all(files.map(async f => {
+        try {
+          const r = await fetch(`/api/traces/${f}`, { cache: 'no-store' });
+          return r.ok ? await r.json() : null;
+        } catch { return null; }
+      }));
+      goals = traces.filter(Boolean).map(traceToGoal);
+    } else {
+      const r = await fetch(`${TRACE_BASE}/build-run.json`, { cache: 'no-store' });
+      if (!r.ok) { setMeta('no data', false); return; }
+      const data = JSON.parse(await r.text());
+      goals = data.goals || [];
+    }
+
+    const h = hashStr(JSON.stringify(goals.map(g => g.name)));
+    if (h === lastHash) return;
+    lastHash = h;
+    buildRun = { goalCount: goals.length, timestamp: new Date().toISOString(), goals };
+    setMeta(`${buildRun.goalCount} goals | ${buildRun.timestamp?.substring(0,19).replace('T',' ')}`, true);
+    renderGoalList();
+    if (selectedGoalIndex === null && buildRun.goals.length > 0) {
+      selectGoal(0);
+    } else if (selectedGoalIndex !== null) {
+      renderGoalDetail(selectedGoalIndex);
+    }
+  } catch(e) {
+    setMeta('error: ' + e.message, false);
+  }
+}
+
+function traceToGoal(trace) {
+  const pass1 = trace.pass1 || {};
+  const resp = pass1.response || {};
+  const steps = (resp.steps || []).map(s => ({
+    index: s.index,
+    text: s.guidance || '',
+    finalLevel: s.level || 'high',
+    finalConfidence: s.confidence || 0,
+    actions: s.actions || [],
+    flow: [
+      { phase: 'buildGoal', level: s.level || 'high', confidence: s.confidence || 0, guidance: s.guidance || '' },
+      { phase: 'validate', status: (s.actions?.length > 0) ? 'pass' : 'error' },
+      { phase: 'applyStep', status: 'merged' }
+    ]
+  }));
+  return {
+    name: trace.goal || '?',
+    path: '', status: 'ok',
+    timestamp: trace.timestamp || '',
+    stepCount: steps.length,
+    buildGoal: { system: pass1.system || '', user: pass1.user || '', response: JSON.stringify(resp, null, 2) },
+    steps
+  };
+}
+
+function setMeta(text, live) {
+  const el = document.getElementById('build-meta');
+  el.textContent = text;
+  el.className = live ? 'meta live' : 'meta';
+}
+
+// ---------- Sidebar ----------
+
+function renderGoalList() {
+  const list = document.getElementById('goal-list');
+  list.innerHTML = '';
+  if (!buildRun) return;
+
+  buildRun.goals.forEach((g, i) => {
+    const stepCount = g.steps?.length || g.stepCount || 0;
+    const detailCount = countDetails(g);
+    const errorCount = countErrors(g);
+
+    const div = document.createElement('div');
+    div.className = 'goal-item' + (i === selectedGoalIndex ? ' active' : '');
+    div.innerHTML = `
+      <div class="goal-info">
+        <span class="goal-name">${esc(g.name)}</span>
+        <span class="goal-path">${esc(g.path || '')}</span>
+      </div>
+      <div class="goal-badges">
+        <span class="badge badge-steps">${stepCount}</span>
+        ${errorCount > 0 ? `<span class="badge badge-err">${errorCount} err</span>` : ''}
+        ${detailCount > 0 ? `<span class="badge badge-detail">${detailCount} detail</span>` : ''}
+        ${errorCount === 0 && detailCount === 0 ? `<span class="badge badge-ok">ok</span>` : ''}
+      </div>
+    `;
+    div.onclick = () => selectGoal(i);
+    list.appendChild(div);
+  });
+}
+
+function countDetails(goal) {
+  return (goal.steps || []).filter(s => s.flow?.some(f => f.phase === 'buildStep')).length;
+}
+function countErrors(goal) {
+  return (goal.steps || []).filter(s => s.flow?.some(f => f.status === 'error')).length;
+}
+
+function selectGoal(idx) {
+  selectedGoalIndex = idx;
+  renderGoalList();
+  renderGoalDetail(idx);
+}
+
+// ---------- Main panel ----------
+
+function renderGoalDetail(idx) {
+  const main = document.getElementById('main');
+  const g = buildRun.goals[idx];
+  if (!g) { main.className = 'empty'; main.innerHTML = '<span>Goal not found</span>'; return; }
+  main.className = '';
+
+  const steps = g.steps || [];
+  const detailCount = countDetails(g);
+  const errorCount = countErrors(g);
+
+  let html = `
+    <div class="goal-header">
+      <h1>${esc(g.name)}</h1>
+      <div class="subtitle">
+        <span>${esc(g.path || '')}</span>
+        <span>${steps.length} steps</span>
+        ${g.duration ? `<span>${esc(g.duration)}</span>` : ''}
+        ${detailCount > 0 ? `<span style="color:var(--blue)">${detailCount} detail passes</span>` : ''}
+        ${errorCount > 0 ? `<span style="color:var(--accent)">${errorCount} validation errors (recovered)</span>` : ''}
+      </div>
+    </div>
+  `;
+
+  // BuildGoal LLM call (collapsible)
+  if (g.buildGoal) {
+    html += `
+      <div class="buildgoal-llm">
+        <div class="buildgoal-llm-title" onclick="toggleEl(this.nextElementSibling)">
+          <span>BuildGoal LLM Call</span>
+          <span style="font-size:11px;color:var(--text-dim)">${sizeLabel(g.buildGoal.system || '')} system | ${sizeLabel(g.buildGoal.user || '')} user</span>
+        </div>
+        <div class="buildgoal-llm-body">
+          ${renderPromptBlocks(g.buildGoal.system, g.buildGoal.user, g.buildGoal.response)}
+        </div>
+      </div>
+    `;
+  }
+
+  // Steps
+  for (const step of steps) {
+    const hasError = step.flow?.some(f => f.status === 'error');
+    const hasDetail = step.flow?.some(f => f.phase === 'buildStep');
+    const cardClass = hasError ? 'has-error' : hasDetail ? 'has-detail' : '';
+
+    html += `<div class="step-card ${cardClass}">`;
+
+    // Step header with flow pipeline
+    html += `
+      <div class="step-header" onclick="toggleStepBody(this)">
+        <span class="step-index">${step.index}</span>
+        <span class="step-text">${esc(step.text)}</span>
+        <span class="step-status">
+          ${renderConfBadge(step.finalLevel, step.finalConfidence)}
+        </span>
+      </div>
+    `;
+
+    // Flow pipeline (always visible)
+    html += `<div class="step-flow">${renderFlowPipeline(step.flow)}</div>`;
+
+    // Error detail (auto-shown)
+    const errorPhase = (step.flow || []).find(f => f.status === 'error');
+    if (errorPhase) {
+      html += `<div class="error-detail">${esc(errorPhase.error || 'validation error')}</div>`;
+    }
+
+    // Expandable body (detail pass LLM, actions)
+    html += `<div class="step-body${hasError || hasDetail ? ' open' : ''}">`;
+
+    // Detail pass LLM content
+    const detailPhase = (step.flow || []).find(f => f.phase === 'buildStep');
+    if (detailPhase) {
+      html += `
+        <div class="prompt-section">
+          <div class="prompt-section-title">
+            <span>BuildStep Detail Pass</span>
+            <span>${sizeLabel(detailPhase.response || '')}</span>
+          </div>
+          ${renderPromptBlocks(detailPhase.system, detailPhase.user, detailPhase.response)}
+        </div>
+      `;
+    }
+
+    // Actions summary
+    if (step.actions && step.actions.length > 0) {
+      html += `<div class="actions-summary">${renderActions(step.actions, step)}</div>`;
+    }
+
+    html += `</div>`; // step-body
+    html += `</div>`; // step-card
+  }
+
+  main.innerHTML = html;
+}
+
+function renderConfBadge(level, conf) {
+  if (level === 'high') return `<span class="badge badge-ok">${conf}%</span>`;
+  if (level === 'medium') return `<span class="badge badge-warn">${conf}%</span>`;
+  return `<span class="badge badge-err">${conf}%</span>`;
+}
+
+function renderFlowPipeline(flow) {
+  if (!flow || flow.length === 0) return '';
+  return flow.map((f, i) => {
+    const arrow = i > 0 ? '<span class="flow-arrow">&rarr;</span>' : '';
+    let cls = 'phase-neutral';
+    let label = f.phase;
+
+    if (f.phase === 'buildGoal') {
+      cls = f.level === 'high' ? 'phase-pass' : f.level === 'medium' ? 'phase-medium' : 'phase-error';
+      label = `buildGoal: ${f.level} ${f.confidence}%`;
+    } else if (f.phase === 'validate') {
+      cls = f.status === 'pass' ? 'phase-pass' : 'phase-error';
+      label = f.status === 'pass' ? 'validate: pass' : 'validate: ERROR';
+    } else if (f.phase === 'buildStep') {
+      cls = 'phase-detail';
+      label = 'buildStep (detail)';
+    } else if (f.phase === 'applyStep') {
+      cls = 'phase-pass';
+      label = 'apply: merged';
+    }
+
+    return `${arrow}<span class="flow-phase ${cls}">${esc(label)}</span>`;
+  }).join('');
+}
+
+function renderActions(actions, step) {
+  let html = '';
+  for (const a of actions) {
+    const params = (a.parameters || []).map(p => {
+      const typeStr = p.type ? `<span class="param-type">[${esc(p.type)}]</span> ` : '';
+      let val = p.value;
+      if (val !== null && typeof val === 'object') val = JSON.stringify(val);
+      return `<span class="param-name">${esc(p.name)}</span>=${typeStr}<span class="param-value">${esc(String(val ?? ''))}</span>`;
+    }).join(', ');
+    html += `<div class="action-line">${esc(a.module)}.${esc(a.action)} ${params}</div>`;
+  }
+
+  // Show onError / cache if present on the step's buildGoal response
+  if (step._onError) {
+    let parts = [];
+    if (step._onError.retryCount) parts.push(`retry ${step._onError.retryCount}`);
+    if (step._onError.goal?.name) parts.push(`call ${step._onError.goal.name}`);
+    if (step._onError.ignoreError) parts.push('ignore');
+    html += `<div class="modifier-line">onError: ${esc(parts.join(', '))}</div>`;
+  }
+  if (step._cache) {
+    html += `<div class="modifier-line">cache: ${step._cache.durationMs}ms${step._cache.sliding ? ' sliding' : ''}</div>`;
+  }
+
+  return html;
+}
+
+function renderPromptBlocks(system, user, response) {
+  let html = '';
+  if (system) {
+    html += `<div class="block">
+      <div class="block-label" onclick="toggleEl(this.nextElementSibling)">
+        <span>System Prompt</span><span>${sizeLabel(system)}</span>
+      </div>
+      <div class="block-content"><pre>${esc(typeof system === 'string' ? system : JSON.stringify(system, null, 2))}</pre></div>
+    </div>`;
+  }
+  if (user) {
+    html += `<div class="block">
+      <div class="block-label" onclick="toggleEl(this.nextElementSibling)">
+        <span>User Prompt</span><span>${sizeLabel(user)}</span>
+      </div>
+      <div class="block-content open"><pre>${esc(typeof user === 'string' ? user : JSON.stringify(user, null, 2))}</pre></div>
+    </div>`;
+  }
+  if (response) {
+    html += `<div class="block">
+      <div class="block-label" onclick="toggleEl(this.nextElementSibling)">
+        <span>LLM Response</span><span>${sizeLabel(response)}</span>
+      </div>
+      <div class="block-content open"><pre>${esc(typeof response === 'string' ? response : JSON.stringify(response, null, 2))}</pre></div>
+    </div>`;
+  }
+  return html;
+}
+
+// ---------- Interactions ----------
+
+function toggleEl(el) { el.classList.toggle('open'); }
+
+function toggleStepBody(headerEl) {
+  const card = headerEl.closest('.step-card');
+  const body = card.querySelector('.step-body');
+  if (body) body.classList.toggle('open');
+}
+
+// ---------- Polling ----------
+
+poll();
+setInterval(() => {
+  if (document.getElementById('auto-refresh').checked) poll();
+}, POLL_MS);
+</script>
+</body>
+</html>
diff --git a/system/builder/web/server.py b/system/builder/web/server.py
new file mode 100644
index 00000000..f2ec27f7
--- /dev/null
+++ b/system/builder/web/server.py
@@ -0,0 +1,64 @@
+#!/usr/bin/env python3
+"""Simple dev server for the builder trace viewer.
+Serves static files + /api/traces endpoint that lists trace files."""
+
+import http.server
+import json
+import os
+import sys
+
+PORT = int(sys.argv[1]) if len(sys.argv) > 1 else 8080
+ROOT = os.path.abspath(os.path.join(os.path.dirname(__file__), '..', '..', '..'))
+TRACES_DIR = os.path.join(ROOT, '.build', 'traces')
+
+class Handler(http.server.SimpleHTTPRequestHandler):
+    def __init__(self, *args, **kwargs):
+        super().__init__(*args, directory=ROOT, **kwargs)
+
+    def do_GET(self):
+        if self.path == '/api/traces':
+            self.send_trace_list()
+        elif self.path.startswith('/api/traces/'):
+            self.send_trace_file(self.path[len('/api/traces/'):])
+        else:
+            super().do_GET()
+
+    def send_trace_list(self):
+        if not os.path.isdir(TRACES_DIR):
+            self.send_json([])
+            return
+
+        files = sorted([
+            f for f in os.listdir(TRACES_DIR)
+            if f.endswith('.json') and f != 'manifest.json' and f != 'build-run.json'
+        ])
+        self.send_json(files)
+
+    def send_trace_file(self, filename):
+        path = os.path.join(TRACES_DIR, filename)
+        if not os.path.isfile(path) or '..' in filename:
+            self.send_error(404)
+            return
+        try:
+            with open(path, encoding='utf-8') as f:
+                raw = f.read()
+            data = json.loads(raw, strict=False)
+            self.send_json(data)
+        except json.JSONDecodeError:
+            self.send_error(400, 'Invalid JSON in trace file')
+
+    def send_json(self, data):
+        body = json.dumps(data).encode('utf-8')
+        self.send_response(200)
+        self.send_header('Content-Type', 'application/json')
+        self.send_header('Content-Length', str(len(body)))
+        self.send_header('Access-Control-Allow-Origin', '*')
+        self.end_headers()
+        self.wfile.write(body)
+
+    def log_message(self, format, *args):
+        pass  # quiet
+
+print(f'Builder trace viewer: http://localhost:{PORT}/system/builder/web/index.html')
+print(f'API: http://localhost:{PORT}/api/traces')
+http.server.HTTPServer(('', PORT), Handler).serve_forever()
