\":\"Store/Save variable(s) in a persistant storage\",\"MethodName\":\"Store\",\"Parameters\":[{\"Type\":\"System.Collections.Generic.List`1[System.String]\",\"Name\":\"variables\",\"IsRequired\":false},{\"Type\":\"System.String\",\"Name\":\"dataSourceName\",\"IsRequired\":false}]},{\"Description\":\"One or more variables to return. Variable can contain !, e.g. !callback=%callback%. When key is undefined, it is same as value, e.g. return %name% => then variables dictionary has key and value as name=%name%\",\"MethodName\":\"Return\",\"Parameters\":[{\"Type\":\"System.Collections.Generic.Dictionary`2[System.String,System.Object]\",\"Name\":\"variables\",\"IsRequired\":false}]},{\"MethodName\":\"OnCreateVariablesListener\",\"Parameters\":[{\"Type\":\"System.Collections.Generic.List`1[System.String]\",\"Name\":\"keys\",\"IsRequired\":false},{\"Type\":\"PLang.Models.GoalToCallInfo\",\"Name\":\"goalName\",\"Description\":\"(see Type information in SupportingObjects)\",\"IsRequired\":true},{\"Type\":\"System.Boolean\",\"Name\":\"waitForResponse\",\"DefaultValue\":true,\"IsRequired\":false},{\"Type\":\"System.Int32\",\"Name\":\"delayWhenNotWaitingInMilliseconds\",\"DefaultValue\":50,\"IsRequired\":false}]},{\"MethodName\":\"OnChangeVariablesListener\",\"Parameters\":[{\"Type\":\"System.Collections.Generic.List`1[System.String]\",\"Name\":\"keys\",\"IsRequired\":false},{\"Type\":\"PLang.Models.GoalToCallInfo\",\"Name\":\"goalName\",\"Description\":\"(see Type information in SupportingObjects)\",\"IsRequired\":true},{\"Type\":\"System.Boolean\",\"Name\":\"notifyWhenCreated\",\"DefaultValue\":true,\"IsRequired\":false},{\"Type\":\"System.Boolean\",\"Name\":\"waitForResponse\",\"DefaultValue\":true,\"IsRequired\":false},{\"Type\":\"System.Int32\",\"Name\":\"delayWhenNotWaitingInMilliseconds\",\"DefaultValue\":50,\"IsRequired\":false}]},{\"MethodName\":\"OnRemoveVariablesListener\",\"Parameters\":[{\"Type\":\"System.Collections.Generic.List`1[System.String]\",\"Name\":\"keys\",\"IsRequired\":false},{\"Type\":\"PLang.Models.GoalToCallInfo\",\"Name\":\"goalName\",\"Description\":\"(see Type information in SupportingObjects)\",\"IsRequired\":true},{\"Type\":\"System.Boolean\",\"Name\":\"waitForResponse\",\"DefaultValue\":true,\"IsRequired\":false},{\"Type\":\"System.Int32\",\"Name\":\"delayWhenNotWaitingInMilliseconds\",\"DefaultValue\":50,\"IsRequired\":false}]},{\"MethodName\":\"GetEnvironmentVariable\",\"Parameters\":[{\"Type\":\"System.String\",\"Name\":\"key\",\"IsRequired\":true}],\"ReturnValue\":{\"Type\":\"System.String\"}},{\"MethodName\":\"LoadVariables\",\"Parameters\":[{\"Type\":\"System.String\",\"Name\":\"key\",\"IsRequired\":true}],\"ReturnValue\":{\"Type\":\"System.Object\"}},{\"Description\":\"Set string variable. Developer might use single/double quote to indicate the string value, the wrapped quote should not be included in the value. If value is json, make sure to format it as valid json, use double quote(\\\") by escaping it\",\"MethodName\":\"SetStringVariable\",\"Parameters\":[{\"Type\":\"System.String\",\"Name\":\"key\",\"IsRequired\":true},{\"Type\":\"System.String\",\"Name\":\"value\",\"IsRequired\":false},{\"Type\":\"System.Boolean\",\"Name\":\"urlDecode\",\"DefaultValue\":false,\"IsRequired\":false},{\"Type\":\"System.Boolean\",\"Name\":\"htmlDecode\",\"DefaultValue\":false,\"IsRequired\":false},{\"Type\":\"System.Boolean\",\"Name\":\"doNotLoadVariablesInValue\",\"DefaultValue\":false,\"IsRequired\":false},{\"Type\":\"System.String\",\"Name\":\"defaultValue\",\"IsRequired\":false}]},{\"Description\":\"Set json variable. Make sure value is valid json\",\"MethodName\":\"SetJsonObjectVariable\",\"Parameters\":[{\"Type\":\"System.String\",\"Name\":\"key\",\"IsRequired\":true},{\"Type\":\"System.Object\",\"Name\":\"value\",\"IsRequired\":false},{\"Type\":\"System.Boolean\",\"Name\":\"doNotLoadVariablesInValue\",\"DefaultValue\":false,\"IsRequired\":false},{\"Type\":\"System.Object\",\"Name\":\"defaultValue\",\"IsRequir