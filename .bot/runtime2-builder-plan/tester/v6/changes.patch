+  .goal-item:hover { background: var(--surface2); }
+  .goal-item.active { background: var(--surface2); border-left: 3px solid var(--accent); }
+  .goal-item .goal-info { flex: 1; min-width: 0; }
+  .goal-item .goal-name {
+    display: block;
+    font-weight: 500;
+    white-space: nowrap;
