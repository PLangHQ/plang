+        {
+            "app" => App.GetStatic(key),
+            _ => (ConcurrentDictionary<string, object?>)_data.GetOrAdd(key,
+                _ => new ConcurrentDictionary<string, object?>(StringComparer.OrdinalIgnoreCase))
