+
+  #controls {
+    padding: 12px 16px;
+    border-top: 1px solid var(--border);
+    font-size: 12px;
+    display: flex;
+    align-items: center;
+    gap: 8px;
+  }
+  #controls label { cursor: pointer; color: var(--text-dim); }
+
+  /* Main panel */
+  #main {
+    flex: 1;
+    overflow-y: auto;
+    padding: 24px 32px;
+  }
+  #main.empty {
+    display: flex;
+    align-items: center;
+    justify-content: center;
+    color: var(--text-dim);
+    font-size: 15px;
+  }
+
+  /* Goal header */
+  .goal-header {
+    margin-bottom: 24px;
+    padding-bottom: 16px;
+    border-bottom: 1px solid var(--border);
+  }
+  .goal-header h1 {
+    font-size: 22px;
