{
  "name": "ValidateStep",
  "description": "Validates a single step from the LLM response — every step must have actions.",
  "steps": [
    {
      "index": 0,
      "text": "if %step.actions% is empty",
      "lineNumber": 2,
      "indent": 0,
      "actions": [
        {
          "module": "condition",
          "action": "if",
          "parameters": [
            {
              "name": "Left",
              "value": "%step.actions%",
              "type": "object"
            },
            {
              "name": "Operator",
              "value": "isempty",
              "type": "string"
            }
          ]
        }
      ],
      "waitForExecution": true
    },
    {
      "index": 1,
      "text": "throw error 'Step at index %step.index% has no actions. Every step must include actions with module and action filled in.'",
      "lineNumber": 3,
      "indent": 1,
      "actions": [
        {
          "module": "error",
          "action": "throw",
          "parameters": [
            {
              "name": "Message",
              "value": "Step at index %step.index% has no actions. Every step must include actions with module and action filled in.",
              "type": "string"
            }
          ]
        }
      ],
      "waitForExecution": true
    }
  ],
  "goals": [],
