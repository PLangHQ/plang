      "type": "PLang.Modules.GenericFunctionBuilder",
      "caching": true,
      "RawResponse": "{\n  \"Reasoning\": \"The user wants to validate that the variables %step.ModuleType%, %stepResult.method%, and %stepResult.data% are not empty. The appropriate function to use is IsNotEmpty, which checks if variables are empty and can generate an error message if validation fails. The error handling is specified separately and can be ignored in this step.\",\n  \"Name\": \"IsNotEmpty\",\n  \"Parameters\": [\n    {\n      \"Type\": \"System.Collections.Generic.List`1[PLang.Runtime.ObjectValue]\",\n      \"Name\": \"variables\",\n      \"Value\": [\n        \"%step.ModuleType%\",\n        \"%stepResult.method%\",\n        \"%stepResult.data%\"\n      ]\n    },\n    {\n      \"Type\": \"PLang.Services.OutputStream.Messages.ErrorMessage\",\n      \"Name\": \"errorMessage\",\n      \"Value\": {\n        \"Content\": \"One or more required variables are empty: %step.ModuleType%, %stepResult.method%, %stepResult.data%\",\n        \"Key\": \"ValidationError\",\n        \"Kind\": \"Error\",\n        \"Level\": \"error\",\n        \"StatusCode\": 400,\n        \"Channel\": \"default\",\n        \"Actor\": \"user\"\n      }\n    }\n  ],\n  \"ReturnValues\": null\n}",
