{
  "name": "ValidateBuildResponse",
  "steps": [
    {
      "index": 0,
      "text": "if %response.steps.Count% is not %goal.Steps.Count%, throw error 'LLM returned %response.steps.Count% steps but goal has %goal.Steps.Count% steps. Steps are lines starting with '- '. Return exactly one result per goal step.'",
      "lineNumber": 3,
      "indent": 0,
      "actions": [
        {
          "module": "condition",
          "action": "if",
          "parameters": [
            {
              "name": "Left",
              "value": "%response.steps.Count%",
              "type": "object"
            },
            {
              "name": "Operator",
              "value": "!=",
              "type": "string"
            },
            {
              "name": "Right",
              "value": "%goal.Steps.Count%",
              "type": "object"
            }
          ]
        }
      ],
      "waitForExecution": true
    },
    {
      "index": 1,
      "text": "throw error 'LLM returned %response.steps.Count% steps but goal has %goal.Steps.Count% steps'",
      "lineNumber": 3,
      "indent": 1,
      "actions": [
        {
          "module": "error",
          "action": "throw",
          "parameters": [
            {
              "name": "Message",
              "value": "LLM returned %response.steps.Count% steps but goal has %goal.Steps.Count% steps. Steps are lines starting with '- '. Return exactly one result per goal step.",
              "type": "string"
            }
          ]
        }
      ],
      "waitForExecution": true
    },
    {
      "index": 2,
      "text": "foreach %response.steps%, call ValidateStep, item=%step%",
      "lineNumber": 4,
      "indent": 0,
      "actions": [
        {
          "module": "loop",
          "action": "foreach",
          "parameters": [
            {
              "name": "Collection",
              "value": "%response.steps%",
              "type": "list"
            },
            {
              "name": "ItemName",
              "value": "step",
              "type": "string"
            }
          ]
        },
        {
          "module": "goal",
          "action": "call",
          "parameters": [
            {
              "name": "GoalName",
              "value": {
                "name": "ValidateStep"
              },
              "type": "goal.call"
            }
          ]
        }
      ],
      "waitForExecution": true
    }
  ],
  "goals": [
    {
      "name": "ValidateStep",
      "steps": [
        {
          "index": 0,
          "text": "if %step.actions% is empty",
          "lineNumber": 8,
          "indent": 0,
          "actions": [
            {
              "module": "condition",
              "action": "if",
              "parameters": [
                {
                  "name": "Left",
                  "value": "%step.actions%",
                  "type": "object"
                },
                {
                  "name": "Operator",
                  "value": "isEmpty",
                  "type": "string"
                },
                {
                  "name": "Right",
                  "value": null,
                  "type": "object"
                }
              ]
            }
          ],
          "waitForExecution": true
        },
        {
          "index": 1,
          "text": "throw error 'Step at index %step.index% has no actions. Every step must include actions with module and action filled in.'",
          "lineNumber": 9,
          "indent": 1,
          "actions": [
            {
              "module": "error",
              "action": "throw",
              "parameters": [
