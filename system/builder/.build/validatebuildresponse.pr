{
  "name": "ValidateBuildResponse",
  "description": "Validates the LLM build response — step count must match goal, every step must have actions.",
  "steps": [
    {
      "index": 0,
      "text": "if %response.steps.Count% != %goal.Steps.Count%",
      "lineNumber": 3,
      "indent": 0,
      "actions": [
        {
          "module": "condition",
          "action": "if",
          "parameters": [
            {"name": "Left", "value": "%response.steps.Count%", "type": "int"},
            {"name": "Operator", "value": "!="},
            {"name": "Right", "value": "%goal.Steps.Count%", "type": "int"}
          ]
        }
      ],
      "waitForExecution": true
    },
    {
      "index": 1,
      "text": "throw error step count mismatch",
      "lineNumber": 4,
      "indent": 1,
      "actions": [
        {
          "module": "error",
          "action": "throw",
          "parameters": [
            {"name": "Message", "value": "LLM returned %response.steps.Count% steps but goal has %goal.Steps.Count% steps. Steps are lines starting with '- '. Return exactly one result per goal step.", "type": "string"}
          ]
        }
      ],
      "waitForExecution": true
    },
    {
      "index": 2,
      "text": "foreach %response.steps%, call ValidateStep, item=%step%",
      "lineNumber": 5,
      "indent": 0,
      "actions": [
        {
          "module": "loop",
          "action": "foreach",
          "parameters": [
            {"name": "Collection", "value": "%response.steps%", "type": "list"},
            {"name": "GoalName", "value": {"name": "ValidateStep"}, "type": "goal.call"},
            {"name": "ItemName", "value": "step", "type": "string"}
          ]
        }
      ],
      "waitForExecution": true
    }
  ],
  "goals": [
    {
      "name": "ValidateStep",
      "steps": [
        {
          "index": 0,
          "text": "if %step.actions% is empty",
          "lineNumber": 8,
          "indent": 0,
          "actions": [
            {
              "module": "condition",
              "action": "if",
              "parameters": [
                {"name": "Left", "value": "%step.actions%", "type": "object"},
                {"name": "Operator", "value": "isempty"}
              ]
            }
          ],
          "waitForExecution": true
        },
        {
          "index": 1,
          "text": "throw error 'Step has no actions'",
          "lineNumber": 9,
          "indent": 1,
          "actions": [
            {
              "module": "error",
              "action": "throw",
              "parameters": [
                {"name": "Message", "value": "Step at index %step.index% has no actions. Every step must include actions with module and action filled in.", "type": "string"}
              ]
            }
          ],
          "waitForExecution": true
        }
      ],
      "goals": [],
      "visibility": 0,
      "path": "/system/builder/ValidateBuildResponse.goal",
      "prPath": "/system/builder/.build/validatebuildresponse.pr",
      "isSystem": true
    }
  ],
  "visibility": 1,
  "path": "/system/builder/ValidateBuildResponse.goal",
  "prPath": "/system/builder/.build/validatebuildresponse.pr",
  "isSystem": true
}
