{
  "name": "ValidateBuildResponse",
  "description": "Validates the LLM build response — step count matches and each step has actions.",
  "comment": null,
  "steps": [
    {
      "index": 0,
      "text": "if %stepResults.steps.Count% is not %goal.Steps.Count%, throw error 'LLM returned %stepResults.steps.Count% steps but goal has %goal.Steps.Count% steps. Steps are lines starting with '- '. Return exactly one result per goal step.'",
      "lineNumber": 3,
      "indent": 0,
      "comment": null,
      "actions": [
        {
          "module": "condition",
          "action": "if",
          "parameters": [
            { "name": "Left", "value": "%stepResults.steps.Count%", "type": "object" },
            { "name": "Operator", "value": "!=", "type": "string" },
            { "name": "Right", "value": "%goal.Steps.Count%", "type": "object" },
            { "name": "Negate", "value": false, "type": "bool" }
          ]
        },
        {
          "module": "error",
          "action": "throw",
          "parameters": [
            { "name": "Message", "value": "LLM returned %stepResults.steps.Count% steps but goal has %goal.Steps.Count% steps. Steps are lines starting with '- '. Return exactly one result per goal step.", "type": "tstring" }
          ]
        }
      ],
      "waitForExecution": true
    },
    {
      "index": 1,
      "text": "foreach %stepResults.steps%, call ValidateStep, item=%step%",
      "lineNumber": 4,
      "indent": 0,
      "comment": null,
      "actions": [
        {
          "module": "loop",
          "action": "foreach",
          "parameters": [
            { "name": "Collection", "value": "%stepResults.steps%", "type": "object" },
            { "name": "ItemName", "value": "step", "type": "string" }
          ]
        },
        {
          "module": "goal",
          "action": "call",
          "parameters": [
            { "name": "GoalName", "value": { "name": "ValidateStep" }, "type": "goal.call" }
          ]
        }
      ],
      "waitForExecution": true
    }
  ],
  "goals": [
    {
      "name": "ValidateStep",
      "description": "Validates a single step from the LLM response.",
      "comment": null,
      "steps": [
        {
          "index": 0,
          "text": "if %step.actions% is empty",
          "lineNumber": 8,
          "indent": 0,
          "comment": null,
          "actions": [
            {
              "module": "condition",
              "action": "if",
              "parameters": [
                { "name": "Left", "value": "%step.actions%", "type": "object" },
                { "name": "Operator", "value": "isempty", "type": "string" },
                { "name": "Right", "value": "%step.actions%", "type": "object" },
                { "name": "Negate", "value": false, "type": "bool" }
              ]
            }
          ],
          "waitForExecution": true
        },
        {
          "index": 1,
          "text": "throw error 'Step at index %step.index% has no actions. Every step must include actions with module and action filled in.'",
          "lineNumber": 9,
          "indent": 4,
          "comment": null,
          "actions": [
            {
              "module": "error",
              "action": "throw",
              "parameters": [
                { "name": "Message", "value": "Step at index %step.index% has no actions. Every step must include actions with module and action filled in.", "type": "tstring" }
              ]
            }
          ],
          "waitForExecution": true
        },
        {
          "index": 2,
          "text": "builder.validate actions=%step.actions%",
          "lineNumber": 10,
          "indent": 0,
          "comment": null,
          "actions": [
            {
              "module": "builder",
              "action": "validate",
              "parameters": [
                { "name": "Actions", "value": "%step.actions%", "type": "object" }
              ]
            }
          ],
          "waitForExecution": true
        }
      ],
      "goals": [],
      "visibility": 1,
      "path": "/system/builder/ValidateBuildResponse.goal",
      "prPath": "/system/builder/.build/validatebuildresponse.pr",
      "builderVersion": "0.2.2",
      "isSetup": false,
      "isEvent": false,
      "isSystem": true,
      "isTest": false,
      "inputParameters": null
    }
  ],
  "visibility": 1,
  "path": "/system/builder/ValidateBuildResponse.goal",
  "prPath": "/system/builder/.build/validatebuildresponse.pr",
  "builderVersion": "0.2.2",
  "isSetup": false,
