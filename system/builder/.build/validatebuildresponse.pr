{
  "name": "ValidateBuildResponse",
  "description": "Validates that the LLM build response contains exactly one step per goal step, then validates each returned step via ValidateStep.",
  "comment": null,
  "steps": [
    {
      "index": 0,
      "text": "if %response.steps.Count% is not %goal.Steps.Count%, throw error \u0027LLM returned %response.steps.Count% steps but goal has %goal.Steps.Count% steps. Steps are lines starting with \u0027- \u0027. Return exactly one result per goal step.\u0027",
      "lineNumber": 3,
      "indent": 0,
      "comment": "Validates the LLM build response",
      "actions": [
        {
          "module": "condition",
          "action": "if",
          "parameters": [
            {
              "name": "Left",
              "value": "%response.steps.Count%",
              "type": "string"
            },
            {
              "name": "Operator",
              "value": "!=",
              "type": "string"
            },
            {
              "name": "Right",
              "value": "%goal.Steps.Count%",
              "type": "string"
            },
            {
              "name": "GoalIfTrue",
              "value": {
                "name": "throw",
                "type": "goal.call"
              },
              "type": "dict\u003Cstring,object\u003E"
            },
            {
              "name": "GoalIfFalse",
              "value": {
                "name": "noop",
                "type": "goal.call"
              },
              "type": "dict\u003Cstring,object\u003E"
            },
            {
              "name": "Negate",
              "value": false,
              "type": "bool"
            },
            {
              "name": "Step",
              "value": {
                "name": "throw",
                "type": "goal.call"
              },
              "type": "dict\u003Cstring,object\u003E"
            }
          ],
          "return": null,
          "defaults": null
        }
      ],
      "intent": null,
      "onError": null,
      "cache": null,
      "timeout": null,
      "waitForExecution": true
    },
    {
      "index": 1,
      "text": "foreach %response.steps%, call ValidateStep, item=%step%",
      "lineNumber": 4,
      "indent": 0,
      "comment": null,
      "actions": [
        {
          "module": "loop",
          "action": "foreach",
          "parameters": [
            {
              "name": "Collection",
              "value": "%response.steps%",
              "type": "list"
            },
            {
              "name": "GoalName",
              "value": {
                "name": "ValidateStep",
                "parameters": [
                  {
                    "name": "item",
                    "value": "%step%",
                    "type": "object"
                  }
                ]
              },
              "type": "goal.call"
            },
            {
              "name": "ItemName",
              "value": "step",
              "type": "string"
            }
          ],
          "return": null,
          "defaults": null
        }
      ],
      "intent": null,
      "onError": null,
      "cache": null,
      "timeout": null,
      "waitForExecution": true
    }
  ],
  "goals": [
    {
      "name": "ValidateStep",
      "description": null,
      "comment": null,
      "steps": [
        {
          "index": 0,
          "text": "if %step.actions% is empty",
          "lineNumber": 8,
          "indent": 0,
          "comment": "Validates a single step from the LLM response",
          "actions": [],
          "intent": null,
          "onError": null,
          "cache": null,
          "timeout": null,
          "waitForExecution": true
        },
        {
          "index": 1,
          "text": "throw error \u0027Step at index %step.index% has no actions. Every step must include actions with module and action filled in.\u0027",
          "lineNumber": 9,
          "indent": 1,
          "comment": null,
          "actions": [],
          "intent": null,
