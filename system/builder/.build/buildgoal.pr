              ]
            }
          ],
          "waitForExecution": true
        },
        {
          "index": 8,
          "text": "set %trace% = {\"id\": \"%traceId%\", \"goal\": \"%goal.Name%\", \"timestamp\": \"%Now%\", \"pass1\": {\"system\": \"%buildGoalPrompt%\", \"user\": \"%goalForLlm%\", \"response\": \"%stepResults%\"}, \"detailPasses\": []}, type=json",
          "lineNumber": 26,
          "indent": 0,
          "comment": null,
          "actions": [
