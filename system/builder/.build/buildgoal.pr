    {
      "name": "ProcessGroup",
      "description": "Process a group of steps — if level is low or medium, run BuildStep; then ApplyStep for all.",
      "comment": null,
      "steps": [
        {
          "index": 0,
          "text": "if %group.steps[0].level% is \"low\" or \"medium\"",
          "lineNumber": 42,
