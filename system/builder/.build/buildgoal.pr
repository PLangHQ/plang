              ]
            }
          ],
          "waitForExecution": true
        },
        {
          "index": 9,
          "text": "group %stepResults.steps% by \"level\", write to %groupedSteps%",
          "lineNumber": 27,
          "indent": 0,
          "comment": null,
          "actions": [
            {
              "module": "list",
              "action": "group",
              "parameters": [
