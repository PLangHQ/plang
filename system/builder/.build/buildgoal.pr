          ],
          "waitForExecution": true
        },
        {
          "index": 7,
          "text": "set %traceId% = %Now.Ticks%_%goal.Name%",
          "lineNumber": 25,
          "indent": 0,
          "comment": null,
          "actions": [
            {
              "module": "variable",
              "action": "set",
