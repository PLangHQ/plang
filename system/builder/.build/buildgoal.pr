    {
      "index": 5,
      "text": "read file \"llm/BuildGoal.llm\", load vars, write to %buildGoalPrompt%",
      "lineNumber": 12,
      "indent": 0,
      "actions": [
        {
          "module": "file",
          "action": "read",
          "parameters": [
            {
              "name": "Path",
              "value": "llm/BuildGoal.llm",
              "type": "path"
            },
            {
              "name": "ResolveVariables",
              "value": true,
