{
  "name": "BuildGoal",
  "description": "Builds a single goal via a single LLM pass. Falls back to BuildStep for steps needing detail.",
  "steps": [
    {
      "index": 0,
      "text": "write out \"Building goal: %goal.Name%\"",
      "lineNumber": 7,
      "indent": 0,
      "actions": [
        {
          "module": "output",
          "action": "write",
          "parameters": [
            { "name": "Data", "value": "Building goal: %goal.Name%", "type": "string" }
          ]
        }
      ],
      "waitForExecution": true
    },
    {
      "index": 1,
      "text": "[plang] get all actions, write to %actions%",
      "lineNumber": 8,
      "indent": 0,
      "actions": [
        {
          "module": "builder",
          "action": "actions",
          "parameters": []
        },
        {
          "module": "variable",
          "action": "set",
          "parameters": [
            { "name": "Name", "value": "%actions%", "type": "string" },
            { "name": "Value", "value": "%__data__%", "type": "object" }
          ]
        }
      ],
      "waitForExecution": true
    },
    {
      "index": 2,
      "text": "[plang] get type info, write to %typeInfo%",
      "lineNumber": 9,
      "indent": 0,
      "actions": [
        {
          "module": "builder",
          "action": "types",
          "parameters": []
        },
        {
          "module": "variable",
          "action": "set",
          "parameters": [
            { "name": "Name", "value": "%typeInfo%", "type": "string" },
            { "name": "Value", "value": "%__data__%", "type": "object" }
          ]
        }
      ],
      "waitForExecution": true
    },
    {
      "index": 3,
      "text": "render template \"/system/actions/v2/summary.md\", write to %actionSummary%",
      "lineNumber": 10,
      "indent": 0,
      "actions": [
        {
          "module": "ui",
          "action": "render",
          "parameters": [
            { "name": "Template", "value": "/system/actions/v2/summary.md", "type": "string" },
            { "name": "IsFile", "value": true, "type": "bool" }
          ]
        },
        {
          "module": "variable",
          "action": "set",
          "parameters": [
            { "name": "Name", "value": "%actionSummary%", "type": "string" },
            { "name": "Value", "value": "%__data__%", "type": "object" }
          ]
        }
      ],
      "waitForExecution": true
    },
    {
      "index": 4,
      "text": "render template \"/system/builder/templates/v2/goalFormatForLlm.template\", write to %goalForLlm%",
      "lineNumber": 11,
      "indent": 0,
      "actions": [
        {
          "module": "ui",
          "action": "render",
          "parameters": [
            { "name": "Template", "value": "/system/builder/templates/v2/goalFormatForLlm.template", "type": "string" },
            { "name": "IsFile", "value": true, "type": "bool" }
          ]
        },
        {
          "module": "variable",
          "action": "set",
          "parameters": [
            { "name": "Name", "value": "%goalForLlm%", "type": "string" },
            { "name": "Value", "value": "%__data__%", "type": "object" }
          ]
        }
      ],
      "waitForExecution": true
    },
    {
      "index": 5,
      "text": "read file \"llm/BuildGoal.llm\", load vars, write to %buildGoalPrompt%",
      "lineNumber": 12,
      "indent": 0,
      "actions": [
        {
          "module": "file",
          "action": "read",
          "parameters": [
            { "name": "Path", "value": "llm/BuildGoal.llm", "type": "path" },
            { "name": "ResolveVariables", "value": true, "type": "bool" }
          ]
        },
        {
          "module": "variable",
          "action": "set",
          "parameters": [
            { "name": "Name", "value": "%buildGoalPrompt%", "type": "string" },
            { "name": "Value", "value": "%__data__%", "type": "object" }
          ]
        }
      ],
      "waitForExecution": true
    },
    {
      "index": 6,
      "text": "[llm] system: %buildGoalPrompt% user: %goalForLlm%",
      "lineNumber": 13,
      "indent": 0,
      "actions": [
        {
          "module": "llm",
          "action": "query",
          "parameters": [
            {
              "name": "Messages",
              "value": [
                { "role": "system", "text": "%buildGoalPrompt%" },
                { "role": "user", "text": "%goalForLlm%" }
              ],
              "type": "object"
            },
            {
              "name": "Schema",
              "value": "{\"description\":\"string\",\"errors?\":[{\"key\":\"string\",\"message\":\"string\"}],\"warnings?\":[{\"key\":\"string\",\"message\":\"string\"}],\"steps\":[{\"index\":\"int\",\"guidance\":\"string\",\"group?\":\"string\",\"actions?\":[{\"module\":\"string\",\"action\":\"string\",\"parameters?\":[{\"name\":\"string\",\"value?\":\"object\",\"type?\":\"string\"}],\"errors?\":[{\"key\":\"string\",\"message\":\"string\"}],\"warnings?\":[{\"key\":\"string\",\"message\":\"string\"}]}],\"errors?\":[{\"key\":\"string\",\"message\":\"string\"}],\"warnings?\":[{\"key\":\"string\",\"message\":\"string\"}],\"cache?\":{\"durationMs\":\"long\",\"sliding?\":\"bool\",\"key?\":\"string\"},\"onError?\":{\"ignoreError?\":\"bool\",\"goal?\":{\"name\":\"string\"},\"retryCount?\":\"int\",\"retryOverMs?\":\"int\",\"order?\":\"string\",\"message?\":\"string\"},\"level\":\"string\",\"confidence\":\"int\"}]}",
              "type": "string"
            },
            { "name": "Format", "value": "json", "type": "string" },
            { "name": "Temperature", "value": 0.0, "type": "double" },
            { "name": "MaxTokens", "value": 8000, "type": "int" },
            { "name": "Cache", "value": "%!build.cache%", "type": "bool" },
            {
              "name": "OnValidateResponse",
              "value": {
                "name": "ValidateBuildResponse",
                "prPath": "/system/builder/.build/validatebuildresponse.pr"
              },
              "type": "goal.call"
            }
          ]
        },
        {
          "module": "variable",
          "action": "set",
          "parameters": [
            { "name": "Name", "value": "%stepResults%", "type": "string" },
            { "name": "Value", "value": "%__data__%", "type": "object" }
          ]
        }
      ],
      "onError": {
        "goal": {
          "name": "HandleBuildGoalFailure",
          "prPath": "/system/builder/.build/handlebuildgoalfailure.pr"
        },
        "ignoreError": false
      },
      "waitForExecution": true
    },
    {
      "index": 7,
      "text": "foreach %stepResults.steps%, call PreValidateStep, item=%stepResult%",
      "lineNumber": 28,
      "indent": 0,
      "actions": [
        {
          "module": "loop",
          "action": "foreach",
          "parameters": [
            { "name": "Collection", "value": "%stepResults.steps%", "type": "object" },
            { "name": "ItemName", "value": "stepResult", "type": "string" }
          ]
        },
        {
          "module": "goal",
          "action": "call",
          "parameters": [
            { "name": "GoalName", "value": {"name": "PreValidateStep"}, "type": "goal.call" }
          ]
        }
      ],
      "waitForExecution": true
    },
    {
      "index": 8,
      "text": "foreach %stepResults.steps%, call ApplyStep, item=%stepResult%",
      "lineNumber": 29,
      "indent": 0,
      "actions": [
        {
          "module": "loop",
          "action": "foreach",
          "parameters": [
            { "name": "Collection", "value": "%stepResults.steps%", "type": "object" },
            { "name": "ItemName", "value": "stepResult", "type": "string" }
          ]
        },
        {
          "module": "goal",
          "action": "call",
          "parameters": [
            { "name": "GoalName", "value": {"name": "ApplyStep"}, "type": "goal.call" }
          ]
        }
      ],
      "waitForExecution": true
    },
    {
      "index": 9,
      "text": "set %goal.BuilderVersion% = \"0.2.1\"",
      "lineNumber": 30,
      "indent": 0,
      "actions": [
        {
          "module": "variable",
          "action": "set",
          "parameters": [
            { "name": "Name", "value": "%goal.BuilderVersion%", "type": "string" },
            { "name": "Value", "value": "0.2.1", "type": "string" }
          ]
        }
      ],
      "waitForExecution": true
    },
    {
      "index": 10,
      "text": "[plang] call SaveGoal %goal%",
      "lineNumber": 31,
      "indent": 0,
      "actions": [
        {
          "module": "builder",
          "action": "goals.save",
          "parameters": [
            { "name": "Goal", "value": "%goal%", "type": "object" }
          ]
        }
      ],
      "waitForExecution": true
    }
  ],
  "goals": [],
  "visibility": 1,
  "path": "/system/builder/BuildGoal.goal",
  "prPath": "/system/builder/.build/buildgoal.pr",
  "hash": "",
  "isSetup": false,
  "isEvent": false,
  "isSystem": true,
  "isTest": false
}
