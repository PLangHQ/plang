    },
    {
      "index": 6,
      "text": "[llm] system: %buildGoalPrompt% user: %goalForLlm%",
      "lineNumber": 13,
      "indent": 0,
      "actions": [
        {
          "module": "llm",
          "action": "query",
          "parameters": [
            {
              "name": "Messages",
              "value": [
                {
                  "role": "system",
                  "text": "%buildGoalPrompt%"
                },
                {
                  "role": "user",
                  "text": "%goalForLlm%"
                }
              ],
              "type": "object"
            },
            {
              "name": "Schema",
              "value": "{\"errors?\":[{\"key\":\"string\",\"message\":\"string\"}],\"warnings?\":[{\"key\":\"string\",\"message\":\"string\"}],\"steps\":[{\"index\":\"int\",\"approved?\":\"bool\",\"rebuildReason?\":\"string\",\"needsDetail?\":\"bool\",\"errors?\":[{\"key\":\"string\",\"message\":\"string\"}],\"warnings?\":[{\"key\":\"string\",\"message\":\"string\"}],\"cache?\":{\"durationSeconds\":\"long\",\"sliding?\":\"bool\",\"key?\":\"string\"},\"onError?\":{\"ignoreError?\":\"bool\",\"goal?\":{\"name\":\"string\"},\"retryCount?\":\"int\",\"retryOverMs?\":\"int\",\"order?\":\"string\",\"message?\":\"string\"},\"actions?\":[{\"module\":\"string\",\"action\":\"string\",\"parameters?\":[{\"name\":\"string\",\"value?\":\"object\",\"type?\":\"string\"}],\"return?\":[{\"name\":\"string\"}],\"errors?\":[{\"key\":\"string\",\"message\":\"string\"}],\"warnings?\":[{\"key\":\"string\",\"message\":\"string\"}]}]}]}",
              "type": "string"
            },
            {
              "name": "Format",
              "value": "json",
              "type": "string"
            },
            {
              "name": "Temperature",
              "value": 0.0,
              "type": "double"
            },
            {
              "name": "MaxTokens",
              "value": 8000,
              "type": "int"
            },
            {
              "name": "Cache",
              "value": false,
              "type": "bool"
            }
          ],
          "return": [
            {
              "name": "stepResults"
            }
          ],
          "errors": [],
          "warnings": []
        }
      ],
      "onError": {
        "goal": {
          "name": "HandleBuildGoalFailure"
        },
        "ignoreError": false
      },
      "errors": [],
      "warnings": [],
      "waitForExecution": true
    },
    {
      "index": 7,
      "text": "foreach %stepResults.steps%, call ApplyStep, item=%stepResult%",
      "lineNumber": 29,
      "indent": 0,
      "actions": [
        {
          "module": "loop",
          "action": "foreach",
          "parameters": [
            {
              "name": "Collection",
              "value": "%stepResults.steps%",
              "type": "object"
            },
            {
              "name": "GoalName",
              "value": "ApplyStep",
              "type": "goal.call"
            },
            {
              "name": "ItemName",
              "value": "%stepResult%",
              "type": "string"
            }
          ],
          "errors": [],
          "warnings": []
        }
      ],
      "errors": [],
      "warnings": [],
      "waitForExecution": true
    },
