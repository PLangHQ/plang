          "waitForExecution": true
        },
        {
          "index": 4,
          "text": "render template \"/system/builder/llm/BuildGoal.llm\", write to %buildGoalPrompt%",
          "lineNumber": 22,
          "indent": 0,
          "comment": null,
          "actions": [
            {
              "module": "ui",
              "action": "render",
              "parameters": [
                { "name": "Template", "value": "/system/builder/llm/BuildGoal.llm", "type": "string" },
                { "name": "IsFile", "value": true, "type": "bool" }
