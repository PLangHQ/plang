              "module": "variable",
              "action": "set",
              "parameters": [
                { "name": "Name", "value": "%buildGoalPrompt%", "type": "string" },
                { "name": "Value", "value": "%__data__%", "type": "object" }
              ]
            }
          ],
          "waitForExecution": true
        },
        {
          "index": 5,
          "text": "llm.query system=%buildGoalPrompt%, user=%goalForLlm%, scheme={...}, cache=%!build.cache%, on error HandleBuildGoalFailure, write to %stepResults%",
          "lineNumber": 23,
          "indent": 0,
          "comment": null,
          "actions": [
            {
              "module": "llm",
              "action": "query",
              "parameters": [
                { "name": "Messages", "value": [{ "Role": "system", "Content": "%buildGoalPrompt%" }, { "Role": "user", "Content": "%goalForLlm%" }], "type": "list<llmmessage>" },
                { "name": "Schema", "value": "{\"description\":\"string\",\"errors\":[{\"key\":\"string\",\"message\":\"string\"}],\"warnings\":[{\"key\":\"string\",\"message\":\"string\"}],\"steps\":[{\"index\":\"int\",\"guidance\":\"string\",\"actions\":[{\"module\":\"string\",\"action\":\"string\",\"parameters\":[{\"name\":\"string\",\"value\":\"object\",\"type\":\"string\"}],\"errors\":[{\"key\":\"string\",\"message\":\"string\"}],\"warnings\":[{\"key\":\"string\",\"message\":\"string\"}]}],\"errors\":[{\"key\":\"string\",\"message\":\"string\"}],\"warnings\":[{\"key\":\"string\",\"message\":\"string\"}],\"level\":\"string\",\"confidence\":\"int\"}]}", "type": "string" },
                { "name": "Cache", "value": "%!build.cache%", "type": "bool" }
