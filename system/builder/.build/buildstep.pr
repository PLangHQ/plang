{
  "name": "BuildStep",
  "description": "Builds a step that needs detailed action info. Action suggestions already on step from BuildGoal.",
  "comment": "Builds a step that needs detailed action info\nAction suggestions (module + action) already on step from BuildGoal",
  "steps": [
    {
      "index": 0,
      "text": "read file \"llm/BuildStep.llm\", load vars, write to %buildStepPrompt%",
      "lineNumber": 4,
      "indent": 0,
      "actions": [
        {
          "module": "file",
          "action": "read",
          "parameters": [
            {
              "name": "Path",
              "value": "llm/BuildStep.llm",
              "type": "path"
            },
            {
              "name": "ResolveVariables",
              "value": true,
              "type": "bool"
            }
          ],
          "return": [
            {
              "name": "buildStepPrompt"
            }
          ],
          "errors": [],
          "warnings": []
        }
      ],
      "errors": [],
      "warnings": [],
      "waitForExecution": true
    },
    {
      "index": 1,
      "text": "[llm] system: %buildStepPrompt% user: %step.Serialize.Builder%",
      "lineNumber": 5,
      "indent": 0,
      "actions": [
        {
          "module": "llm",
          "action": "query",
          "parameters": [
            {
              "name": "Messages",
              "value": [
                {
                  "role": "system",
                  "text": "%buildStepPrompt%"
                },
                {
                  "role": "user",
                  "text": "%step.Serialize.Builder%"
                }
              ],
              "type": "object"
            },
            {
              "name": "Schema",
              "value": "{\"errors?\":[{\"key\":\"string\",\"message\":\"string\"}],\"warnings?\":[{\"key\":\"string\",\"message\":\"string\"}],\"actions\":[{\"module\":\"string\",\"action\":\"string\",\"parameters?\":[{\"name\":\"string\",\"value?\":\"object\",\"type?\":\"string\"}],\"return?\":[{\"name\":\"string\"}],\"errors?\":[{\"key\":\"string\",\"message\":\"string\"}],\"warnings?\":[{\"key\":\"string\",\"message\":\"string\"}]}]}",
              "type": "string"
            },
            {
              "name": "Format",
              "value": "json",
              "type": "string"
            },
            {
              "name": "Temperature",
              "value": 0.0,
              "type": "double"
            },
            {
              "name": "Cache",
              "value": false,
              "type": "bool"
            }
          ],
          "return": [
            {
              "name": "result"
            }
          ],
          "errors": [],
          "warnings": []
        }
      ],
      "onError": {
        "goal": {
          "name": "HandleBuildStepFailure"
        },
        "ignoreError": false
      },
      "errors": [],
      "warnings": [],
      "waitForExecution": true
    },
    {
      "index": 2,
      "text": "set %goal.Steps[stepResult.index].actions% = %result.actions%",
      "lineNumber": 16,
      "indent": 0,
      "actions": [
