{
  "name": "BuildStep",
  "description": "Builds a single step via a focused LLM call with full action-detail context.",
  "comment": null,
  "steps": [
    {
      "index": 0,
      "text": "set %step% = %goal.Steps[stepResult.index]%",
      "lineNumber": 4,
      "indent": 0,
      "comment": null,
      "actions": [
        {
          "module": "variable",
          "action": "set",
          "parameters": [
            { "name": "Name", "value": "%step%", "type": "string" },
            { "name": "Value", "value": "%goal.Steps[stepResult.index]%", "type": "object" }
          ]
        }
      ],
      "waitForExecution": true
    },
    {
      "index": 1,
      "text": "render template \"/system/builder/templates/v2/stepForLlm.template\", write to %stepForLlm%",
      "lineNumber": 5,
      "indent": 0,
      "comment": null,
      "actions": [
        {
          "module": "ui",
          "action": "render",
          "parameters": [
            { "name": "Template", "value": "/system/builder/templates/v2/stepForLlm.template", "type": "string" },
            { "name": "IsFile", "value": true, "type": "bool" }
          ]
        },
        {
          "module": "variable",
          "action": "set",
          "parameters": [
            { "name": "Name", "value": "%stepForLlm%", "type": "string" },
            { "name": "Value", "value": "%__data__%", "type": "object" }
          ]
        }
      ],
      "waitForExecution": true
    },
    {
      "index": 2,
      "text": "render template \"/system/builder/templates/v2/stepActionDetails.template\", write to %actionDetails%",
      "lineNumber": 6,
      "indent": 0,
      "comment": null,
      "actions": [
        {
          "module": "ui",
          "action": "render",
          "parameters": [
            { "name": "Template", "value": "/system/builder/templates/v2/stepActionDetails.template", "type": "string" },
            { "name": "IsFile", "value": true, "type": "bool" }
          ]
        },
        {
          "module": "variable",
          "action": "set",
          "parameters": [
            { "name": "Name", "value": "%actionDetails%", "type": "string" },
            { "name": "Value", "value": "%__data__%", "type": "object" }
          ]
        }
      ],
      "waitForExecution": true
    },
    {
      "index": 3,
      "text": "render template \"/system/builder/llm/BuildStep.llm\", write to %buildStepPrompt%",
      "lineNumber": 7,
      "indent": 0,
      "comment": null,
      "actions": [
        {
          "module": "ui",
          "action": "render",
          "parameters": [
            { "name": "Template", "value": "/system/builder/llm/BuildStep.llm", "type": "string" },
            { "name": "IsFile", "value": true, "type": "bool" }
          ]
        },
        {
          "module": "variable",
          "action": "set",
          "parameters": [
            { "name": "Name", "value": "%buildStepPrompt%", "type": "string" },
            { "name": "Value", "value": "%__data__%", "type": "object" }
          ]
        }
      ],
      "waitForExecution": true
    },
    {
      "index": 4,
      "text": "llm.query system=%buildStepPrompt%, user=%stepForLlm%, scheme={...}, cache=%!build.cache%, on error call HandleBuildStepFailure, write to %result%",
      "lineNumber": 8,
      "indent": 0,
      "comment": null,
      "actions": [
        {
          "module": "llm",
          "action": "query",
          "parameters": [
            { "name": "Messages", "value": [{ "Role": "system", "Content": "%buildStepPrompt%" }, { "Role": "user", "Content": "%stepForLlm%" }], "type": "list<llmmessage>" },
            { "name": "Schema", "value": "{\"errors\":[{\"key\":\"string\",\"message\":\"string\"}],\"warnings\":[{\"key\":\"string\",\"message\":\"string\"}],\"actions\":[{\"module\":\"string\",\"action\":\"string\",\"parameters\":[{\"name\":\"string\",\"value\":\"object\",\"type\":\"string\"}],\"errors\":[{\"key\":\"string\",\"message\":\"string\"}],\"warnings\":[{\"key\":\"string\",\"message\":\"string\"}]}]}", "type": "string" },
            { "name": "Cache", "value": "%!build.cache%", "type": "bool" }
          ],
          "modifiers": [
            {
              "module": "error",
              "action": "handle",
              "parameters": [
                { "name": "Goal", "value": { "name": "HandleBuildStepFailure" }, "type": "goal.call" }
              ]
            }
          ]
        },
        {
          "module": "variable",
          "action": "set",
          "parameters": [
            { "name": "Name", "value": "%result%", "type": "string" },
            { "name": "Value", "value": "%__data__%", "type": "object" }
          ]
        }
      ],
      "waitForExecution": true
    },
    {
      "index": 5,
      "text": "add {stepIndex: %stepResult.index%, stepText: %step.Text%, level: %stepResult.level%, system: %buildStepPrompt%, user: %stepForLlm%, response: %result%} to %trace.detailPasses%",
      "lineNumber": 9,
      "indent": 0,
      "comment": null,
      "actions": [
        {
          "module": "list",
          "action": "add",
          "parameters": [
            { "name": "Value", "value": { "stepIndex": "%stepResult.index%", "stepText": "%step.Text%", "level": "%stepResult.level%", "system": "%buildStepPrompt%", "user": "%stepForLlm%", "response": "%result%" }, "type": "json" },
            { "name": "ListName", "value": "%trace.detailPasses%", "type": "string" }
          ]
        }
      ],
      "waitForExecution": true
    },
    {
      "index": 6,
      "text": "save %trace% to file '/.build/traces/%goal.Name%.json'",
      "lineNumber": 10,
      "indent": 0,
      "comment": null,
      "actions": [
        {
          "module": "file",
          "action": "save",
          "parameters": [
            { "name": "Path", "value": "/.build/traces/%goal.Name%.json", "type": "path" },
            { "name": "Value", "value": "%trace%", "type": "object" }
          ]
        }
      ],
      "waitForExecution": true
    },
    {
      "index": 7,
      "text": "call ValidateBuildStepResult",
      "lineNumber": 11,
      "indent": 0,
      "comment": null,
      "actions": [
        {
          "module": "goal",
          "action": "call",
          "parameters": [
            { "name": "GoalName", "value": { "name": "ValidateBuildStepResult" }, "type": "goal.call" }
          ]
        }
      ],
      "waitForExecution": true
    },
    {
      "index": 8,
      "text": "set %goal.Steps[stepResult.index].Actions% = %result.actions%",
      "lineNumber": 12,
      "indent": 0,
      "comment": null,
      "actions": [
        {
          "module": "variable",
          "action": "set",
          "parameters": [
            { "name": "Name", "value": "%goal.Steps[stepResult.index].Actions%", "type": "string" },
            { "name": "Value", "value": "%result.actions%", "type": "object" }
          ]
        }
      ],
      "waitForExecution": true
    },
    {
      "index": 9,
      "text": "builder.validate actions=%goal.Steps[stepResult.index].Actions%",
      "lineNumber": 13,
      "indent": 0,
      "comment": null,
      "actions": [
        {
          "module": "builder",
          "action": "validate",
          "parameters": [
            { "name": "Actions", "value": "%goal.Steps[stepResult.index].Actions%", "type": "object" }
          ]
        }
      ],
      "waitForExecution": true
    }
  ],
  "goals": [
    {
      "name": "ValidateBuildStepResult",
      "description": "Checks LLM output for top-level or action-level errors.",
      "comment": null,
      "steps": [
        {
          "index": 0,
          "text": "if %result.errors% is not empty, call ThrowBuildStepErrors",
          "lineNumber": 17,
          "indent": 0,
          "comment": null,
          "actions": [
            {
              "module": "condition",
              "action": "if",
              "parameters": [
                { "name": "Left", "value": "%result.errors%", "type": "object" },
                { "name": "Operator", "value": "isempty", "type": "string" },
                { "name": "Right", "value": "%result.errors%", "type": "object" },
                { "name": "Negate", "value": true, "type": "bool" }
              ]
            },
            {
              "module": "goal",
              "action": "call",
              "parameters": [
                { "name": "GoalName", "value": { "name": "ThrowBuildStepErrors" }, "type": "goal.call" }
              ]
            }
          ],
          "waitForExecution": true
        },
        {
          "index": 1,
          "text": "foreach %result.actions%, call ValidateActionErrors, item=%action%",
          "lineNumber": 18,
          "indent": 0,
          "comment": null,
          "actions": [
            {
              "module": "loop",
              "action": "foreach",
              "parameters": [
                { "name": "Collection", "value": "%result.actions%", "type": "object" },
                { "name": "ItemName", "value": "action", "type": "string" }
              ]
            },
            {
              "module": "goal",
              "action": "call",
              "parameters": [
                { "name": "GoalName", "value": { "name": "ValidateActionErrors" }, "type": "goal.call" }
              ]
            }
          ],
          "waitForExecution": true
        }
      ],
      "goals": [],
      "visibility": 1,
      "path": "/system/builder/BuildStep.goal",
      "prPath": "/system/builder/.build/buildstep.pr",
      "builderVersion": "0.2.2",
      "isSetup": false,
      "isEvent": false,
      "isSystem": true,
      "isTest": false,
      "inputParameters": null
    },
    {
      "name": "ThrowBuildStepErrors",
      "description": "Throws a formatted error for the BuildStep LLM top-level errors.",
      "comment": null,
      "steps": [
        {
          "index": 0,
          "text": "throw error \"BuildStep failed for step '%step.Text%': %result.errors%\"",
          "lineNumber": 21,
          "indent": 0,
          "comment": null,
          "actions": [
            {
              "module": "error",
              "action": "throw",
              "parameters": [
                { "name": "Message", "value": "BuildStep failed for step '%step.Text%': %result.errors%", "type": "tstring" }
              ]
            }
          ],
          "waitForExecution": true
        }
      ],
      "goals": [],
      "visibility": 1,
      "path": "/system/builder/BuildStep.goal",
      "prPath": "/system/builder/.build/buildstep.pr",
      "builderVersion": "0.2.2",
      "isSetup": false,
      "isEvent": false,
      "isSystem": true,
      "isTest": false,
      "inputParameters": null
    },
    {
      "name": "ValidateActionErrors",
      "description": "Throws if an action has errors.",
      "comment": null,
      "steps": [
        {
          "index": 0,
          "text": "if %action.errors% is not empty, call ThrowActionErrors",
          "lineNumber": 24,
          "indent": 0,
          "comment": null,
          "actions": [
            {
              "module": "condition",
              "action": "if",
              "parameters": [
                { "name": "Left", "value": "%action.errors%", "type": "object" },
                { "name": "Operator", "value": "isempty", "type": "string" },
                { "name": "Right", "value": "%action.errors%", "type": "object" },
                { "name": "Negate", "value": true, "type": "bool" }
              ]
            },
            {
              "module": "goal",
              "action": "call",
              "parameters": [
                { "name": "GoalName", "value": { "name": "ThrowActionErrors" }, "type": "goal.call" }
              ]
            }
          ],
          "waitForExecution": true
        }
      ],
      "goals": [],
      "visibility": 1,
      "path": "/system/builder/BuildStep.goal",
      "prPath": "/system/builder/.build/buildstep.pr",
      "builderVersion": "0.2.2",
      "isSetup": false,
      "isEvent": false,
      "isSystem": true,
      "isTest": false,
      "inputParameters": null
    },
    {
      "name": "ThrowActionErrors",
      "description": "Throws a formatted error for a failing action.",
      "comment": null,
      "steps": [
        {
          "index": 0,
          "text": "throw error \"Action %action.module%.%action.action% failed for step '%step.Text%': %action.errors%\"",
          "lineNumber": 27,
          "indent": 0,
          "comment": null,
          "actions": [
            {
              "module": "error",
              "action": "throw",
              "parameters": [
                { "name": "Message", "value": "Action %action.module%.%action.action% failed for step '%step.Text%': %action.errors%", "type": "tstring" }
              ]
            }
          ],
          "waitForExecution": true
        }
      ],
      "goals": [],
      "visibility": 1,
      "path": "/system/builder/BuildStep.goal",
      "prPath": "/system/builder/.build/buildstep.pr",
      "builderVersion": "0.2.2",
      "isSetup": false,
      "isEvent": false,
      "isSystem": true,
      "isTest": false,
      "inputParameters": null
    },
    {
      "name": "HandleBuildStepFailure",
      "description": "Logs and rethrows a BuildStep failure.",
      "comment": null,
      "steps": [
        {
          "index": 0,
          "text": "write out \"  Build step error: %!error.Message%\"",
          "lineNumber": 30,
          "indent": 0,
          "comment": null,
          "actions": [
            {
              "module": "output",
              "action": "write",
              "parameters": [
                { "name": "Data", "value": "  Build step error: %!error.Message%", "type": "tstring" }
              ]
            }
          ],
          "waitForExecution": true
        },
        {
          "index": 1,
          "text": "throw %!error%",
          "lineNumber": 31,
          "indent": 0,
          "comment": null,
          "actions": [
            {
              "module": "error",
              "action": "throw",
              "parameters": [
                { "name": "Message", "value": "%!error.Message%", "type": "tstring" }
              ]
            }
          ],
          "waitForExecution": true
        }
      ],
