{
  "name": "BuildStep",
  "description": "Writes a build-step error message (with null-safe handling) and then throws the provided error object.",
  "comment": null,
  "steps": [
    {
      "index": 0,
      "text": "set %step% = %goal.Steps[stepResult.index]%",
