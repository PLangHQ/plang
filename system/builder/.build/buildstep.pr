{
  "name": "BuildStep",
  "description": "Builds a step that needs detailed action info. Action suggestions already on step from BuildGoal.",
  "steps": [
    {
      "index": 0,
      "text": "set %step% = %goal.Steps[stepResult.index]%",
      "lineNumber": 4,
      "indent": 0,
      "actions": [
        {
          "module": "variable",
          "action": "set",
          "parameters": [
            {
              "name": "Name",
              "value": "%step%",
              "type": "string"
            },
            {
              "name": "Value",
              "value": "%goal.Steps[stepResult.index]%",
              "type": "object"
            }
          ]
        }
      ],
      "waitForExecution": true
    },
    {
      "index": 1,
      "text": "render template \"/system/builder/templates/v2/stepForLlm.template\", write to %stepForLlm%",
      "lineNumber": 5,
      "indent": 0,
      "actions": [
        {
          "module": "ui",
          "action": "render",
          "parameters": [
            {
              "name": "Template",
              "value": "/system/builder/templates/v2/stepForLlm.template",
              "type": "string"
            },
            {
              "name": "IsFile",
              "value": true,
              "type": "bool"
            }
          ],
          "return": [
            {
              "name": "stepForLlm"
            }
          ]
        }
      ],
      "waitForExecution": true
    },
    {
      "index": 2,
      "text": "render template \"/system/builder/templates/v2/stepActionDetails.template\", write to %actionDetails%",
      "lineNumber": 6,
      "indent": 0,
      "actions": [
        {
          "module": "ui",
          "action": "render",
          "parameters": [
            {
              "name": "Template",
              "value": "/system/builder/templates/v2/stepActionDetails.template",
              "type": "string"
            },
            {
              "name": "IsFile",
              "value": true,
              "type": "bool"
            }
          ],
          "return": [
            {
              "name": "actionDetails"
            }
          ]
        }
      ],
      "waitForExecution": true
    },
    {
      "index": 3,
      "text": "read file \"llm/BuildStep.llm\", load vars, write to %buildStepPrompt%",
      "lineNumber": 7,
      "indent": 0,
      "actions": [
        {
          "module": "file",
          "action": "read",
          "parameters": [
            {
              "name": "Path",
              "value": "llm/BuildStep.llm",
              "type": "path"
            },
            {
              "name": "ResolveVariables",
              "value": true,
              "type": "bool"
            }
          ],
          "return": [
            {
              "name": "buildStepPrompt"
            }
          ]
        }
      ],
      "waitForExecution": true
    },
    {
      "index": 4,
      "text": "[llm] system: %buildStepPrompt% user: %stepForLlm%",
      "lineNumber": 8,
      "indent": 0,
      "actions": [
        {
          "module": "llm",
          "action": "query",
          "parameters": [
            {
              "name": "Messages",
              "value": [
                {
                  "role": "system",
                  "text": "%buildStepPrompt%"
                },
                {
                  "role": "user",
                  "text": "%stepForLlm%"
                }
              ],
              "type": "object"
            },
            {
              "name": "Schema",
              "value": "{\"errors?\":[{\"key\":\"string\",\"message\":\"string\"}],\"warnings?\":[{\"key\":\"string\",\"message\":\"string\"}],\"actions\":[{\"module\":\"string\",\"action\":\"string\",\"parameters?\":[{\"name\":\"string\",\"value?\":\"object\",\"type?\":\"string\"}],\"return?\":[{\"name\":\"string\"}],\"errors?\":[{\"key\":\"string\",\"message\":\"string\"}],\"warnings?\":[{\"key\":\"string\",\"message\":\"string\"}]}]}",
              "type": "string"
            },
            {
              "name": "Format",
              "value": "json",
              "type": "string"
            },
            {
              "name": "Temperature",
              "value": 0.0,
              "type": "double"
            },
            {
              "name": "MaxTokens",
              "value": 8000,
              "type": "int"
            },
            {
              "name": "Cache",
              "value": "%!build.cache%",
              "type": "bool"
            }
          ],
          "return": [
            {
              "name": "result"
            }
          ]
        }
      ],
      "onError": {
        "goal": {
          "name": "HandleBuildStepFailure"
        },
        "ignoreError": false
      },
      "waitForExecution": true
    },
    {
      "index": 5,
      "text": "call ValidateBuildStepResult",
      "lineNumber": 19,
      "indent": 0,
      "actions": [
        {
          "module": "goal",
          "action": "call",
          "parameters": [
            {
              "name": "GoalName",
              "value": {
                "name": "ValidateBuildStepResult"
              },
              "type": "goal.call"
            }
          ]
        }
      ],
      "waitForExecution": true
    },
    {
      "index": 6,
      "text": "set %goal.Steps[stepResult.index].Actions% = %result.actions%",
      "lineNumber": 20,
      "indent": 0,
      "actions": [
        {
          "module": "variable",
          "action": "set",
          "parameters": [
            {
              "name": "Name",
              "value": "%goal.Steps[stepResult.index].Actions%",
              "type": "string"
            },
            {
              "name": "Value",
              "value": "%result.actions%",
              "type": "object"
            }
          ]
        }
      ],
      "waitForExecution": true
    },
    {
      "index": 7,
      "text": "[plang] ValidateActions, actions=%goal.Steps[stepResult.index].Actions%",
      "lineNumber": 21,
      "indent": 0,
      "actions": [
        {
          "module": "builder",
          "action": "actions.validate",
          "parameters": [
            {
              "name": "Actions",
              "value": "%goal.Steps[stepResult.index].Actions%",
              "type": "object"
            }
          ]
        }
      ],
      "waitForExecution": true
    }
  ],
