BuildGoal
/ Builds a single goal and its sub-goals
/ Delegates LLM pass to BuildGoalCore, then handles version + sub-goals + save

- write out "Building goal: %goal.Name%"
- call BuildGoalCore
- set %goal.Version% = "0.2.1"
- set %parentGoal% = %goal%
- foreach %parentGoal.Goals%, call BuildSubGoal item=%subGoal%
- set %goal% = %parentGoal%
- call SaveGoal %goal%


BuildGoalCore
/ Core LLM build pass — shared by top-level goals and sub-goals
/ Sends goal text + action summary to LLM, validates, applies steps, saves trace

- builder.actions, write to %actions%
- builder.types, write to %typeInfo%
- render template "/system/actions/v2/summary.md", write to %actionSummary%
- render template "/system/builder/templates/v2/goalFormatForLlm.template", write to %goalForLlm%
- render template "/system/builder/llm/BuildGoal.llm", write to %buildGoalPrompt%
- llm.query system=%buildGoalPrompt%, user=%goalForLlm%, scheme={description: string, errors?: [{key: string, message: string}], warnings?: [{key: string, message: string}], steps: [{index: int, guidance: string, actions?: [{module: string, action: string, parameters?: [{name: string, value?: object, type?: string}], errors?: [{key: string, message: string}], warnings?: [{key: string, message: string}]}], errors?: [{key: string, message: string}], warnings?: [{key: string, message: string}], cache?: {durationMs: long, sliding?: bool, key?: string}, onError?: {ignoreError?: bool, goal?: {name: string}, retryCount?: int, retryOverMs?: int, order?: string, message?: string}, level: string, confidence: int}]}, cache=%!build.cache%, on error HandleBuildGoalFailure, write to %stepResults%
- builder.validateResponse stepResults=%stepResults%, goal=%goal%, on error call LlmFixer
- set %traceId% = %Now.Ticks%_%goal.Name%
- set %trace% = {"id": "%traceId%", "goal": "%goal.Name%", "timestamp": "%Now%", "pass1": {"system": "%buildGoalPrompt%", "user": "%goalForLlm%", "response": "%stepResults%"}, "detailPasses": []}, type=json
- group %stepResults.steps% by "level", write to %groupedSteps%
- loop.foreach %groupedSteps%, goal.call ProcessGroup item=%group%
- save %trace% to file '/.build/traces/%traceId%.json'
- add %traceId% to %traceGoals%


BuildSubGoal
/ Builds a single sub-goal — no version, no sub-goal recursion, no save
- set %goal% = %subGoal%
- write out "  Building sub-goal: %goal.Name%"
- call BuildGoalCore


ProcessGroup
/ Process a group of steps with the same confidence level
- if %group.steps[0].level% is "low" or "medium"
    - foreach %group.steps%, call BuildStep item=%stepResult%
- foreach %group.steps%, call ApplyStep item=%stepResult%


LlmFixer
/ LLM produced invalid output — retry with error context
- write out "  Validation failed: %!error.Message% — retrying..."
- llm.query system=%buildGoalPrompt%, user="Your previous response had an error: %!error.Message%. The developer's PLang code is:\n%goalForLlm%\n\nYour previous answer:\n%stepResults%\n\nFix the error and return the correct response.", scheme={description: string, errors?: [{key: string, message: string}], warnings?: [{key: string, message: string}], steps: [{index: int, guidance: string, actions?: [{module: string, action: string, parameters?: [{name: string, value?: object, type?: string}], errors?: [{key: string, message: string}], warnings?: [{key: string, message: string}]}], errors?: [{key: string, message: string}], warnings?: [{key: string, message: string}], cache?: {durationMs: long, sliding?: bool, key?: string}, onError?: {ignoreError?: bool, goal?: {name: string}, retryCount?: int, retryOverMs?: int, order?: string, message?: string}, level: string, confidence: int}]}, cache=%!build.cache%, write to %stepResults%
- call ValidateBuildResponse


HandleBuildGoalFailure
- write out "  Build error: %!error.Message%"
- throw %!error%
