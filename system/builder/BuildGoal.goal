BuildGoal
/ Builds a single goal - single LLM pass
/ LLM sees entire goal + compact action summary with DTOs
/ Returns complete [{module, action, parameters}] for all steps
/ Falls back to BuildStep for steps with level medium or low

- write out "Building goal: %goal.Name%"
- get all actions, write to %actions%
- get type info, write to %typeInfo%
- render template "/system/actions/v2/summary.md", write to %actionSummary%
- render template "/system/builder/templates/goalFormatForLlm.template", write to %goalForLlm%
- read file "llm/BuildGoal.llm", load vars, write to %buildGoalPrompt%
- [llm] system: %buildGoalPrompt%
        user: %goalForLlm%
         scheme: {
            description: string,
            errors?: [{key: string, message: string}],
            warnings?: [{key: string, message: string}],
            steps: [{index: int, guidance: string,
                  actions?: [{module: string, action: string, parameters?: [{name: string, value?: object, type?: string}],
                              errors?: [{key: string, message: string}],
                              warnings?: [{key: string, message: string}]}],
                  errors?: [{key: string, message: string}],
                  warnings?: [{key: string, message: string}],
                  cache?: {durationMs: long, sliding?: bool, key?: string},
                  onError?: {ignoreError?: bool, goal?: {name: string}, retryCount?: int, retryOverMs?: int, order?: string, message?: string},
                  level: string, confidence: int}]
                }
        on error HandleBuildGoalFailure
        write to %stepResults%
- set %trace% = {goal: %goal.Name%, pass1: {system: %buildGoalPrompt%, user: %goalForLlm%, response: %stepResults%}, detailPasses: []}
- foreach %stepResults.steps%, call ApplyStep, item=%stepResult%
- save %trace% to file '/.build/traces/%goal.Name%.json'
- add %goal.Name% to %traceGoals%
- save %traceGoals% to file '/.build/traces/manifest.json'
- set %goal.Version% = "0.2.1"
- call SaveGoal %goal%


HandleBuildGoalFailure
- write out "  Build error: %!error.Message%"
- throw %!error%