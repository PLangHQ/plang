BuildStep
/ Builds a step that needs detailed action info
/ Action suggestions (module + action) already on step from BuildGoal
- set %step% = %goal.Steps[stepResult.index]%
- render template "/system/builder/templates/v2/stepForLlm.template", write to %stepForLlm%
- render template "/system/builder/templates/v2/stepActionDetails.template", write to %actionDetails%
- read file "llm/BuildStep.llm", load vars, write to %buildStepPrompt%
- [llm] system: %buildStepPrompt%
        user: %stepForLlm%
        scheme: {
                errors?: [{key: string, message: string}],
                warnings?: [{key: string, message: string}],
                actions: [{module: string, action: string, parameters?: [{name: string, value?: object, type?: string}],
                    errors?: [{key: string, message: string}],
                    warnings?: [{key: string, message: string}]}]
                }
        on error call HandleBuildStepFailure
        write to %result%
- add {stepIndex: %stepResult.index%, stepText: %step.Text%, level: %stepResult.level%, system: %buildStepPrompt%, user: %stepForLlm%, response: %result%} to %trace.detailPasses%
- save %trace% to file '.build/traces/%goal.Name%.json'
- call ValidateBuildStepResult
- set %goal.Steps[stepResult.index].Actions% = %result.actions%
- [plang] ValidateActions, actions=%goal.Steps[stepResult.index].Actions%

ValidateBuildStepResult
/ Check for top-level and action-level errors from the BuildStep LLM
- if %result.errors% is not empty, call ThrowBuildStepErrors
- foreach %result.actions%, call ValidateActionErrors, item=%action%

ThrowBuildStepErrors
- throw error "BuildStep failed for step '%step.Text%': %result.errors%"

ValidateActionErrors
- if %action.errors% is not empty, call ThrowActionErrors

ThrowActionErrors
- throw error "Action %action.module%.%action.action% failed for step '%step.Text%': %action.errors%"

HandleBuildStepFailure
- write out "  Build step error: %!error.Message%"
- throw %!error%
