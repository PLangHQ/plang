{
  "name": "Test",
  "description": "Discovers and runs *.test.goal files. Collects errors and successfuls for summary.",
  "steps": [
    {
      "index": 0,
      "text": "find files '*.test.goal' in %path% recursive, write to %tests%",
      "indent": 0,
      "actions": [{"module": "file", "action": "list", "parameters": [
        {"name": "Path", "value": "%path%", "type": "path"},
        {"name": "Pattern", "value": "*.test.goal", "type": "string"},
        {"name": "Recursive", "value": true, "type": "bool"}
      ], "return": [{"name": "tests"}]}],
      "waitForExecution": true
    },
    {
      "index": 1,
      "text": "write out 'Found %tests.Count% test files'",
      "indent": 0,
      "actions": [{"module": "output", "action": "write", "parameters": [
        {"name": "Data", "value": "Found %tests.Count% test files", "type": "string"}
      ]}],
      "waitForExecution": true
    },
    {
      "index": 2,
      "text": "foreach %tests%, call RunTest, item=%test%",
      "indent": 0,
      "actions": [
        {"module": "loop", "action": "foreach", "parameters": [
          {"name": "Collection", "value": "%tests%", "type": "list"},
          {"name": "ItemName", "value": "test", "type": "string"}
        ]},
        {"module": "goal", "action": "call", "parameters": [
          {"name": "GoalName", "value": {"name": "RunTest"}, "type": "goal.call"}
        ]}
      ],
      "waitForExecution": true
    },
    {
      "index": 3,
      "text": "write out summary",
      "indent": 0,
      "actions": [{"module": "output", "action": "write", "parameters": [
        {"name": "Data", "value": "\n%successfuls.Count% passed, %errors.Count% failed out of %tests.Count% tests", "type": "string"}
      ]}],
      "waitForExecution": true
    }
  ],
  "goals": [
    {
      "name": "RunTest",
      "steps": [
        {
          "index": 0,
          "text": "write out 'Running %test%'",
          "indent": 0,
          "actions": [{"module": "output", "action": "write", "parameters": [
            {"name": "Data", "value": "Running %test%", "type": "string"}
          ]}],
          "waitForExecution": true
        },
        {
          "index": 1,
          "text": "app run %test.GoalCall%",
          "indent": 0,
          "actions": [{"module": "app", "action": "run", "parameters": [
            {"name": "GoalName", "value": "%test.GoalCall%", "type": "goal.call"}
          ]}],
          "onError": {
            "goal": {
              "name": "TestError",
              "prPath": "/system/.build/test.pr"
            },
            "ignoreError": false
          },
          "waitForExecution": true
        },
        {
          "index": 2,
          "text": "append %test% to %successfuls%",
          "indent": 0,
          "actions": [{"module": "list", "action": "add", "parameters": [
            {"name": "ListName", "value": "successfuls", "type": "string"},
            {"name": "Value", "value": "%test%", "type": "object"}
          ]}],
          "waitForExecution": true
        }
      ],
      "goals": [],
      "visibility": 0,
      "path": "/system/test.goal",
      "prPath": "/system/.build/test.pr",
      "isSystem": true
    },
    {
      "name": "TestError",
      "steps": [
        {
          "index": 0,
          "text": "append %!error% to %errors%",
          "indent": 0,
          "actions": [{"module": "list", "action": "add", "parameters": [
            {"name": "ListName", "value": "errors", "type": "string"},
            {"name": "Value", "value": "%!error%", "type": "object"}
          ]}],
          "waitForExecution": true
        },
        {
          "index": 1,
          "text": "end goal and previous",
          "indent": 0,
          "actions": [{"module": "goal", "action": "return", "parameters": [
            {"name": "Depth", "value": 2, "type": "int"}
          ]}],
          "waitForExecution": true
        }
      ],
      "goals": [],
      "visibility": 0,
      "path": "/system/test.goal",
      "prPath": "/system/.build/test.pr",
      "isSystem": true
    }
  ],
  "visibility": 1,
  "path": "/system/test.goal",
  "prPath": "/system/.build/test.pr",
  "isSystem": true
}
