  "SubGoals": [],
  "Description": "The HandleBuildStepFailure goal is designed to manage errors that occur during a build step. It checks the status code of the error and takes appropriate actions based on its value. If the status code is 402 or greater than or equal to 500, it throws the error. It also appends the error to a list of step errors and checks if the retry count exceeds 3, in which case it ends the goal and the previous two steps. If the retry count is 3 or less, it logs a message indicating the retry attempt and calls the BuildStep function to attempt the build again.",
  "Visibility": 0,
  "GoalFileName": "BuildStep.goal",
  "PrFileName": "00. Goal.pr",
  "RelativeGoalPath": "\\builder\\BuildStep.goal",
