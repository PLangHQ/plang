    {
      "index": 5,
      "text": "call QueryAndValidatePlan, on error call LlmFixer, then retry 2 times",
      "lineNumber": 16,
      "indent": 0,
      "comment": "Wrap llm.query \u002B Validate together so the retry surface catches BOTH\nmalformed-JSON (llm.query throws) and structural validation failures\n(Validate throws step-count-mismatch, etc.). RetryCount=2 is the runtime\u0027s\njob. LlmFixer re-prompts with previousConversation=%plan%.",
      "actions": [
        {
          "module": "goal",
          "action": "call",
          "parameters": [
            {
              "name": "GoalName",
              "value": {
                "name": "QueryAndValidatePlan",
                "parallel": false,
                "parameters": [],
                "prPath": "/system/builder/BuildGoal/.build/plan.pr"
              },
              "type": "goal.call"
            }
          ],
          "defaults": null,
          "modifiers": [
            {
              "module": "error",
              "action": "handle",
              "parameters": [
                {
                  "name": "Actions",
                  "value": [
                    {
                      "module": "goal",
                      "action": "call",
                      "parameters": [
                        {
                          "name": "GoalName",
                          "value": {
                            "name": "LlmFixer",
                            "parameters": []
                          },
                          "type": "goal.call"
                        }
                      ]
                    }
                  ],
                  "type": "list\u003Caction\u003E"
                },
                {
                  "name": "RetryCount",
                  "value": 2,
                  "type": "int"
                }
              ],
              "defaults": null,
              "modifiers": []
            }
          ]
        }
      ],
      "intent": null,
      "formal": "goal.call(GoalName={name:\u0022QueryAndValidatePlan\u0022}) | error.handle(Actions=[goal.call(GoalName={name:\u0022LlmFixer\u0022})], RetryCount=2)",
      "source": null,
      "waitForExecution": true
    },
