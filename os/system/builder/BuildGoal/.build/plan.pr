                          },
                          "type": "goal.call"
                        }
                      ]
                    }
                  ],
                  "type": "list<action>"
                },
                {
                  "name": "RetryCount",
                  "value": 2,
                  "type": "int"
                }
              ],
              "defaults": null,
              "modifiers": []
            }
          ]
        }
      ],
