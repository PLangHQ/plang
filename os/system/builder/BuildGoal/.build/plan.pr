                      "module": "goal",
                      "action": "call",
                      "parameters": [
                        {
                          "name": "GoalName",
                          "value": {
                            "name": "LlmFixer",
                            "parameters": []
                          },
                          "type": "goal.call"
                        }
                      ]
                    }
                  ],
                  "type": "list\u003Caction\u003E"
                },
                {
                  "name": "RetryCount",
                  "value": 2,
                  "type": "int"
                }
              ],
              "defaults": null,
              "modifiers": []
            }
          ]
        }
      ],
      "intent": null,
