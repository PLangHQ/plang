    {
      "name": "QueryAndValidatePlan",
      "description": null,
      "comment": null,
      "steps": [
        {
          "index": 0,
          "text": "llm.query Messages=%messages%, Schema={description: string, steps: [{index: int, actions: [string]}]}, cache=%!build.cache%, write to %plan%",
          "lineNumber": 25,
          "indent": 0,
          "comment": null,
          "actions": [
            {
              "module": "llm",
              "action": "query",
              "parameters": [
                {
                  "name": "Messages",
                  "value": "%messages%",
                  "type": "list\u003Cllmmessage\u003E"
                },
                {
                  "name": "Schema",
                  "value": {
                    "description": "string",
                    "steps": [
                      {
                        "index": "int",
                        "actions": [
                          "string"
                        ]
                      }
                    ]
                  },
                  "type": "dictionary\u00602"
                },
                {
                  "name": "Cache",
                  "value": "%!build.cache%",
                  "type": "bool"
