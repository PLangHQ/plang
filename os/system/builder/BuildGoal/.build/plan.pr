  {
   "index": 5,
   "text": "call QueryAndValidatePlan, on error call LlmFixer, then retry 2 times",
   "lineNumber": 16,
   "comment": "Wrap llm.query + Validate together so the retry surface catches BOTH\nmalformed-JSON (llm.query throws) and structural validation failures\n(Validate throws step-count-mismatch, etc.). RetryCount=2 is the runtime's\njob. LlmFixer re-prompts with previousConversation=%plan%.",
   "formal": "goal.call(GoalName={name:\"QueryAndValidatePlan\"}) | error.handle(Actions=[goal.call(GoalName={name:\"LlmFixer\"})], RetryCount=2)",
   "waitForExecution": true,
   "action": [
    {
     "module": "goal",
     "name": "call",
     "parameter": [
