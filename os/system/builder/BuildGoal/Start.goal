Start
/ Build one .goal file: planner pass, per-step compile, recurse sub-goals.

- call /system/builder/EmitBuildEvent kind="goalHeader", goal=%goal%
- set %buildStart% = %Now.Ticks%
- set %trace% = {"id": "%!trace.id%", "timestamp": "%Now%", "goal": %goal%, "plan": null, "stepPasses": [], "subGoals": [], "durationMs": 0}
- call Plan, on error call HandleBuildFailure
- set %trace.plan% = %plan%

/ The compile system prompt is static across every step in every goal — render
/ it once at goal level so the trace doesn't duplicate ~14KB per step.
- render template "/system/builder/llm/Compile.llm", write to %compileSystemPrompt%
- set %trace.compileSystem% = %compileSystemPrompt%

- foreach %plan.steps%, call BuildStep/Start planStep=%item%, on error call HandleBuildFailure

- set %parentGoal% = %goal%
- foreach %parentGoal.Goals%, call BuildSubGoal subGoal=%item%
- set %goal% = %parentGoal%

- math.subtract A=%Now.Ticks%, B=%buildStart%, write to %elapsedTicks%
- math.divide A=%elapsedTicks%, B=10000, write to %elapsedMs%
- set %trace.durationMs% = %elapsedMs%

- save %trace% to file '/.build/traces/%!trace.id%/%goal.Name%.json'
- add %goal.Name% to %traceGoals%
- build.goalsSave Goal=%goal%


BuildSubGoal
/ Sub-goal recursion — same Plan + per-step pipeline, attach to parent trace.

- set %goal% = %subGoal%
- call /system/builder/EmitBuildEvent kind="subGoalHeader", goal=%goal%
- set %subgoalStart% = %Now.Ticks%
- call Plan, on error call HandleBuildFailure
- foreach %plan.steps%, call BuildStep/Start planStep=%item%, on error call HandleBuildFailure
- add {goal: %goal%, plan: %plan%} to %trace.subGoals%
- math.subtract A=%Now.Ticks%, B=%subgoalStart%, write to %elapsedTicks%
- math.divide A=%elapsedTicks%, B=10000, write to %subgoalMs%
- call /system/builder/EmitBuildEvent kind="subGoalDone", goal=%goal%, subgoalMs=%subgoalMs%


HandleBuildFailure
/ Capture error onto trace, save, rethrow. No null-pass inference.

- call /system/builder/EmitBuildEvent kind="goalError", goal=%goal%, errorMessage=%!error.Message%
- set %trace.buildError% = {"key": "%!error.Key%", "message": "%!error.Message%", "goal": "%goal.Name%"}- save %trace% to file '/.build/traces/%!trace.id%/%goal.Name%.json'
- throw %!error%
