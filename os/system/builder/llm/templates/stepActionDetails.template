{% comment %}
v5: renders from the module-discovery catalog surface. %actions% is the flat action list already
filtered to the planner's set (`where %!app.module.action.list% Name in %planStep.actions%`), so this
template just walks it — no dedup loop. Each action element answers its own Name, Properties (the
declared parameter rows), Return, and prose through lazy `file` doors over
os/system/modules/<module>/{module,<action>}.{description,notes,examples}.md. `{% if x.Notes %}` is an
existence guard (an absent facet file is falsy); `{{ x.Notes }}` emits the md content. Module prose
(x.ModuleX) reaches through the module element; the block concats module-first + action.
{% endcomment %}
{% for a in actions %}
## {{ a.Name }}{% unless a.Cacheable %} [no-cache]{% endunless %}
{% if a.ModuleDescription or a.Description %}
Description:
{% if a.ModuleDescription %}{{ a.ModuleDescription }}
{% endif %}{% if a.Description %}{{ a.Description }}
{% endif %}{% endif %}Parameters:
{% if a.Properties.size > 0 %}{% for p in a.Properties %}  - {{ p.Name }}: {% if p.IsVariable %}%var%{% else %}{{ p.Type }}{% if p.Nullable %}?{% endif %}{% if p.Default %} = {{ p.Default }}{% endif %}{% endif %}
{% endfor %}{% else %}  (no parameters)
{% endif %}{% if a.Return %}→ returns {{ a.Return }}
{% endif %}{% if a.ModuleNotes or a.Notes %}
Notes:
{% if a.ModuleNotes %}{{ a.ModuleNotes }}
{% endif %}{% if a.Notes %}{{ a.Notes }}
{% endif %}{% endif %}{% if a.ModuleExamples or a.Examples %}
Examples:
{% if a.ModuleExamples %}{{ a.ModuleExamples }}
{% endif %}{% if a.Examples %}{{ a.Examples }}
{% endif %}{% endif %}
{% endfor %}
