TestForkedFlowSetDoesNotRewriteParentValue
/ A set inside a parallel-foreach / channel-fired branch must not rewrite a value
/ the parent already stored. Exercises the frame-overlay raw branch (:199) where
/ skipping the rebind reintroduces the alias bug only inside forked flows.
- set %shared% = "parent"
- add %shared% to %captured%
- set %items% = [1, 2]
- foreach %items%, call MutateShared item=%item%
- assert %captured[0]% equals "parent"

MutateShared
- set %shared% = "branch"
