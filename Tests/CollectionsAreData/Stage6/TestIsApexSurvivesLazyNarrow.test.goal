TestIsApexSurvivesLazyNarrow
/ A json value is-a item before and after the lazy narrow: after first navigation
/ it narrows to dict and stays is-a item too. IS-A is preserved through the narrow.
- set %f% = "narrow.json"
- write {city:"Reyk"} to file %f%
- read file %f%, write to %content%
- assert %content% is item
- assert %content.city% equals "Reyk"
- assert %content% is dict
- assert %content% is item
- delete file %f%
