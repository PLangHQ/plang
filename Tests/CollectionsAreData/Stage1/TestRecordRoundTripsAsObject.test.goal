TestRecordRoundTripsAsObject
/ A C# domain record (identity) normalizes to a dict via NormalizeObject and
/ serializes as a JSON object {} — not the deleted property-bag arm, not a list.
/ Written to json and read back, it navigates as an object: %back.name%.
- archive identity 'recordRoundTrip', force, on error ignore
- create identity recordRoundTrip
- get identity 'recordRoundTrip', write to %id%
- set %recFile% = "rec_roundtrip.json"
- write %id% to file %recFile%
- read file %recFile%, write to %back%
- assert %back.name% equals "recordRoundTrip"
- delete file %recFile%
