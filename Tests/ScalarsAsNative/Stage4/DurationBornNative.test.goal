DurationBornNative
/ A duration cast lands the value as duration.@this (born-native), backed by TimeSpan —
/ Type is "duration" and its component parts read off the wrapper.
- set %dur% = "PT1H30M" as duration
- assert %dur.Type.Name% equals "duration"
- assert %dur.Hours% equals 1
- assert %dur.Minutes% equals 30
