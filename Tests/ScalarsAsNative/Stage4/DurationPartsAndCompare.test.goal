DurationPartsAndCompare
/ Durations expose component parts and are orderable by total length — a 90s duration is
/ Minutes=1 Seconds=30 and is longer than a 30s duration.
- set %long% = "PT90S" as duration
- set %short% = "PT30S" as duration
- assert %long.Minutes% equals 1
- assert %long.Seconds% equals 30
- if %long.TotalSeconds% is bigger than %short.TotalSeconds%
    - set %longerWins% = true
- assert %longerWins% is true
