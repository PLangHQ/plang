    {
      "index": 0,
      "text": "set %birthday% = \u00222026-01-01\u0022",
      "lineNumber": 5,
      "indent": 0,
      "comment": "PLang is an intent language: a literal is typed by its form \u002B the variable\u0027s intent, no \u0060as\u0060\nneeded. \u00222026-01-01\u0022 births a date, \u0022PT30S\u0022 a duration, \u002242\u0022 a number; a written date\nnormalizes to ISO; a version-like label under %version% stays text. \u0060as\u0060 is only a force.",
      "actions": [
        {
          "module": "variable",
          "action": "set",
          "parameters": [
            {
              "@schema": "data",
              "name": "Name",
              "type": {
                "name": "variable"
              },
              "value": "%birthday%"
            },
            {
              "@schema": "data",
              "name": "Value",
              "type": {
                "name": "date"
              },
              "value": {
                "year": 2026,
                "month": 1,
                "day": 1,
                "dayofweek": "Thursday",
                "dayofyear": 1,
                "daynumber": 739616
              }
            }
          ],
          "defaults": [
            {
              "@schema": "data",
              "name": "asdefault",
              "type": {
                "name": "bool"
              },
              "value": false
            }
          ],
          "modifiers": []
        }
      ],
