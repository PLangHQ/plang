{
  "name": "TestRunIsolatesMemoryStackBetweenTests",
  "description": "Asserts the per-test variable stack is isolated: probe is null at test start, then set to 1, then verified equals 1.",
  "comment": null,
  "steps": [
    {
      "index": 0,
      "text": "assert %isolation_probe% is null",
      "lineNumber": 7,
      "indent": 0,
      "comment": "Fresh-App-per-test guard. The runner constructs a new App per test, so at\nthe start of every test the user variable stack is empty. Assert the probe\nis unset, set it, then confirm we can read back our own write.\nA regression that made tests share memory would surface as %isolation_probe%\nbeing non-null at entry (if any prior test set it).",
      "actions": [
        {
          "module": "assert",
          "action": "isNull",
          "parameters": [
            {
