  "SubGoals": [
    ".build\\NostrAskHandler\\WaitAndCheck\\00. Goal.pr"
  ],
  "Description": "The HandleNostrAsk goal is designed to facilitate the process of sending a question via Nostr Direct Message (DM) and waiting for a response. It begins by reading the Nostr configuration from a specified file, ensuring that the target for the Nostr ask is properly configured. If the target is not set, an error is thrown. The goal then clears any previous responses and initializes a timer for tracking elapsed time. It sends the specified question to the configured Nostr target and logs the action. The goal enters a waiting state, continuously checking for a response until it is received or a timeout occurs. If a response is not received within the expected timeframe, an error is thrown. Finally, the response is returned for further processing.",
  "Visibility": 1,
  "GoalFileName": "NostrAskHandler.goal",
  "PrFileName": "00. Goal.pr",
  "RelativeGoalPath": "\\NostrAskHandler.goal",
  "CurrentPath": null,
