    {
      "index": 0,
      "text": "archive identity \u0027leakProbe\u0027, force, on error ignore",
      "lineNumber": 6,
      "indent": 0,
      "comment": "Creates an identity, signs a Data with it, and confirms the developer-facing surface\nis intact end-to-end. The cross-actor wire never carries PrivateKey ([Sensitive] excluded\nfrom View.Out) \u2014 that filter behavior is covered by C# WireOutput_Identity_*. This goal\npins the in-process happy path so a regression to the signing surface fails here too.",
      "actions": [
        {
          "module": "identity",
          "action": "archive",
          "parameters": [
            {
              "name": "Name",
              "value": "leakProbe",
              "type": "string"
            },
