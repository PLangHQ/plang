      "index": 0,
      "text": "set settings \u0027maskedTestKey\u0027 = \u0027real-secret-value\u0027",
      "lineNumber": 6,
      "indent": 0,
      "comment": "Round-trips a setting through the local settings store. The value persists locally\nunmasked \u2014 storage honors [Store] and ignores [Masked] so set\u002Bget returns the real\nvalue. The masking-to-\u0022****\u0022 behavior lives on the cross-actor wire path and is\ncovered by C# WireOutput_Setting_KeyVisible_ValueIsFourStars.",
      "actions": [
        {
          "module": "settings",
          "action": "set",
          "parameters": [
            {
              "name": "Key",
              "value": "maskedTestKey",
              "type": "string"
            },
            {
              "name": "Value",
              "value": "real-secret-value",
              "type": "object"
            }
          ],
          "defaults": null,
          "modifiers": []
        }
      ],
      "intent": null,
      "formal": "settings.set(Key=\u0022maskedTestKey\u0022, Value=\u0022real-secret-value\u0022)",
      "source": null,
