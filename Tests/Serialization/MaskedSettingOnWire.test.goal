Start
/ Round-trips a setting through the local settings store. The value persists locally
/ unmasked — storage honors [Store] and ignores [Masked] so set+get returns the real
/ value. The masking-to-"****" behavior lives on the cross-actor wire path and is
/ covered by C# WireOutput_Setting_KeyVisible_ValueIsFourStars.
- set settings 'maskedTestKey' = 'real-secret-value'
- get settings 'maskedTestKey', write to %loaded%
- assert %loaded% equals 'real-secret-value', "storage round-trip preserves real value"
- remove settings 'maskedTestKey'
