Start
/ Failure — if %dict% == %number% (equality, non-coercible cross-type) → Incomparable → PLang error.
- set %d% = '{"a": 1}', type=json
- set %n% = 5
- set %caught% = ""
- if %d% == %n% then
    on error call Caught
    - set %never% = true
- assert %caught% equals "EvaluationError"

Caught
- set %caught% = %!error.Key%
