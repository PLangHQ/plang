Start
/ Cut 5 — enum boundary + membership. %d% a dict, %n% = 5.
/ if %d% > %n% → error; if %d% == %n% → error; if %x% == null → works;
/ if %d% == %d2% → works; [%d%] contains %n% → false, no error.
/ Proves Incomparable/NotEqual boundary, null carve-out, membership-never-errors.
- set %d% = '{"a": 1}', type=json
- set %d2% = '{"a": 1}', type=json
- set %n% = 5
- set %orderCaught% = ""
- if %d% > %n% then
    on error call CaughtOrder
    - set %never1% = true
- assert %orderCaught% equals "EvaluationError"
- set %dictsEqual% = false
- if %d% == %d2% then
    - set %dictsEqual% = true
- assert %dictsEqual% is true
- set %list% = []
- add %d% to %list%
- set %found% = false
- if %list% contains %n% then
    - set %found% = true
- assert %found% is false

CaughtOrder
- set %orderCaught% = %!error.Key%
