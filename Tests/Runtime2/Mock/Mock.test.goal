Start
- mock intercept "file.read", return "mocked content", write to %mockRead%
- assert %mockRead.callCount% equals 0, "mock should start with 0 calls"
- assert %mockRead.actionPattern% equals "file.read"
- assert %mockRead.isSpy% equals false
- mock intercept "output.write", write to %spyWrite%
- assert %spyWrite.isSpy% equals true
/ exercise the mock — call intercepted action, verify callCount
- read file 'test_output.txt', write to %mockResult%
- assert %mockRead.callCount% equals 1, "callCount should increment after mock intercept"
/ verify
- mock verify %mockRead% was called 1 time
/ reset
- mock reset %mockRead%
- assert %mockRead.callCount% equals 0, "reset should clear callCount"
