Start
/ Test: create a named identity, get it by name, verify Name and PublicKey properties
- archive identity 'TestGetByName', on error ignore
- create identity 'TestGetByName'
- get identity 'TestGetByName', write to %id%
- assert %id% is not null
- assert %identity.Name% equals 'TestGetByName'
- assert %identity.PublicKey% is not null
- archive identity 'TestGetByName'
