Start
/ Test: rename an identity, verify old name is gone and new name returns same keys
- archive identity 'TestRenameOld', on error ignore
- archive identity 'TestRenameNew', on error ignore
- create identity 'TestRenameOld'
- get identity 'TestRenameOld', write to %before%
- rename identity 'TestRenameOld' to 'TestRenameNew'
- get identity 'TestRenameNew', write to %after%
- assert %after% is not null
- assert %after.Name% equals 'TestRenameNew'
- assert %after.PublicKey% equals %before.PublicKey%
- archive identity 'TestRenameNew'
