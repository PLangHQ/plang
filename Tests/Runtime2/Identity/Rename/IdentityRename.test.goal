Start
/ Test: rename an identity, verify %MyIdentity.Name% equals new name
- archive identity 'TestRenameOld', on error ignore
- archive identity 'TestRenameNew', on error ignore
- create identity 'TestRenameOld', set as default
- rename identity 'TestRenameOld' to 'TestRenameNew'
- assert %MyIdentity.Name% equals 'TestRenameNew'
- archive identity 'TestRenameNew'
