Start
/ Test: create two identities, archive non-default, verify default unchanged
- archive identity 'TestArcNonDefA', force, on error ignore, force
- archive identity 'TestArcNonDefB', force, on error ignore, force
- create identity 'TestArcNonDefA', set as default
- create identity 'TestArcNonDefB'
- archive identity 'TestArcNonDefB', force
- assert %MyIdentity.Name% equals 'TestArcNonDefA'
- archive identity 'TestArcNonDefA', force
