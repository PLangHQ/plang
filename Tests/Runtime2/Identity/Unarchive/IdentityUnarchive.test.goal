Start
/ Test: archive an identity then unarchive it, verify it is accessible again
- archive identity 'TestUnarchiveId', on error ignore
- archive identity 'TestUnarchiveExtra', on error ignore
- create identity 'TestUnarchiveId', set as default
- create identity 'TestUnarchiveExtra'
- archive identity 'TestUnarchiveExtra'
- get identity 'TestUnarchiveExtra', write to %result%
- assert %result% is null
- unarchive identity 'TestUnarchiveExtra'
- get identity 'TestUnarchiveExtra', write to %result%
- assert %result% is not null
- assert %result.Name% equals 'TestUnarchiveExtra'
- archive identity 'TestUnarchiveExtra'
- archive identity 'TestUnarchiveId'
