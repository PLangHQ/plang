Start
/ save and read
- save "hello world" to file 'test_output.txt'
- read file 'test_output.txt', write to %content%
- assert %content% equals "hello world"
/ exists
- check if file 'test_output.txt' exists, write to %info%
- assert %info% is not null
/ copy
- copy file 'test_output.txt' to 'test_copy.txt'
- read file 'test_copy.txt', write to %copied%
- assert %copied% equals "hello world"
/ move
- move file 'test_copy.txt' to 'test_moved.txt'
- read file 'test_moved.txt', write to %moved%
- assert %moved% equals "hello world"
/ list
- list files in '.', write to %files%
- assert %files% is not null
/ delete + cleanup
- delete file 'test_output.txt'
- delete file 'test_moved.txt'
