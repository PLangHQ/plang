Start
/ Test: verify fails when expected headers don't match signed headers
- create identity testSigner
- set %data% = { "body": "content" }
- set %signHeaders% = { "method": "POST", "url": "/api/send" }
- sign %data% with headers %signHeaders%
- set %wrongHeaders% = { "method": "GET", "url": "/api/send" }
- verify %data% with contracts ['C0'] and headers %wrongHeaders%, on error call HandleHeaderError
- assert %headerFailed% is true, "header mismatch should fail verification"

HandleHeaderError
- set %headerFailed% = true
