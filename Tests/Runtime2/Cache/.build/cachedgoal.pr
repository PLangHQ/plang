{
  "name": "CachedGoal",
  "description": "The CachedGoal is designed to read data from a file named \u0027testdata.txt\u0027 and store the content in a cache variable called \\%cachedMsg\\%. The first call to this goal will read the file and cache its content for 5 minutes. Any subsequent call within this time frame will retrieve the cached content instead of reading the file again. Finally, it outputs the cached message.",
  "steps": [
    {
      "index": 0,
      "text": "read file \u0027testdata.txt\u0027, write to %cachedMsg%\n    cache for 5 minutes",
      "lineNumber": 3,
      "indent": 0,
      "comment": "Called twice from Start - second call should hit cache",
      "actions": [
        {
          "module": "file",
          "action": "read",
          "parameters": [
            {
              "name": "path",
              "value": "testdata.txt",
              "type": "string"
            }
          ],
          "return": [
            {
              "name": "cachedMsg"
            }
          ],
          "errors": [],
          "warnings": []
        }
      ],
      "hash": "66d538520124bbe32d82472f59b3a5005d349b66f27f7651f1ce796ed5b47cf5",
      "cache": {
        "durationSeconds": 300,
        "sliding": false
      },
      "errors": [],
      "warnings": [],
      "waitForExecution": true
    },
    {
      "index": 1,
      "text": "write out \u0022  CachedGoal read: %cachedMsg%\u0022",
      "lineNumber": 5,
      "indent": 0,
      "actions": [
        {
          "module": "output",
          "action": "write",
          "parameters": [
            {
              "name": "content",
              "value": "  CachedGoal read: %cachedMsg%",
              "type": "string"
            },
            {
              "name": "actor",
              "value": "user",
              "type": "actor"
            },
            {
              "name": "channel",
              "value": "default",
              "type": "string"
            }
          ],
          "errors": [],
          "warnings": []
        }
      ],
      "hash": "724999fdd97dda00790432c514e2f6b71995f2e497535e4aff4233f634a3c69b",
      "errors": [],
