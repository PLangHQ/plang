":\"System.Boolean\",\"Name\":\"IsSystemVariable\",\"IsRequired\":true},{\"Type\":\"System.Object\",\"Name\":\"Value\",\"IsRequired\":false},{\"Type\":\"System.Type\",\"Name\":\"Type\",\"IsRequired\":false},{\"Type\":\"System.Boolean\",\"Name\":\"Initiated\",\"IsRequired\":true},{\"Type\":\"PLang.Models.Properties\",\"Name\":\"Properties\",\"IsRequired\":true},{\"Type\":\"System.DateTime\",\"Name\":\"Updated\",\"IsRequired\":true},{\"Type\":\"System.String\",\"Name\":\"Path\",\"IsRequired\":true},{\"Type\":\"System.Collections.Generic.List`1[System.String]\",\"Name\":\"Data\",\"IsRequired\":false}],\"IsRequired\":false},{\"Type\":\"System.IO.Stream\",\"Name\":\"stream\",\"TypeProperties\":[{\"Type\":\"System.Int64\",\"Name\":\"Position\",\"IsRequired\":true},{\"Type\":\"System.Int32\",\"Name\":\"ReadTimeout\",\"IsRequired\":true},{\"Type\":\"System.Int32\",\"Name\":\"WriteTimeout\",\"IsRequired\":true}],\"IsRequired\":false}]}\n## functions available ends ##\n## defined variables ##\nobj (type:object), json (type:object), \n## defined variables ##"
