              "type": "text",
              "text": "## Canonical User Intent (already disambiguated by LLM)\r\nDecode a base64 encoded string stored in the variable %b64% and store the decoded result in the variable %decoded%\n## functions available starts ##\n{\"Description\":\"Encrypt, descryption and hashing & verify using bcrypt, compute Sha256Hash, generate & validate Bearer token\",\"ExampleInformation\":\"Examples with methods first define an example plang code and then(=>) how it is mapped to parameters\",\"Methods\":[{\"MethodName\":\"GetPrivateKey\",\"Parameters\":[],\"ReturnValue\":{\"Type\":\"System.String\"}},{\"MethodName\":\"GetPrivateKeyHash\",\"Parameters\":[],\"ReturnValue\":{\"Type\":\"System.String\"}},{\"MethodName\":\"AddPrivateKey\",\"Parameters\":[{\"Type\":\"System.String\",\"Name\":\"privateKey\",\"IsRequired\":true}]},{\"MethodName\":\"Encrypt\",\"Parameters\":[{\"Type\":\"System.Object\",\"Name\":\"content\",\"IsRequired\":true}],\"ReturnValue\":{\"Type\":\"System.String\"}},{\"MethodName\":\"Decrypt\",\"Parameters\":[{\"Type\":\"System.String\",\"Name\":\"content\",\"IsRequired\":true}],\"ReturnValue\":{\"Type\":\"System.Object\"}},{\"MethodName\":\"ConvertToBase64\",\"Parameters\":[{\"Type\":\"System.String\",\"Name\":\"content\",\"IsRequired\":true}],\"ReturnValue\":{\"Type\":\"System.String\"}},{\"MethodName\":\"ConvertFromBase64\",\"Parameters\":[{\"Type\":\"System.String\",\"Name\":\"base64\",\"IsRequired\":true}],\"ReturnValue\":{\"Type\":\"System.Byte[]\"}},{\"MethodName\":\"CreateSalt\",\"Parameters\":[{\"Type\":\"System.Int32\",\"Name\":\"workFactor\",\"DefaultValue\":12,\"IsRequired\":false}],\"ReturnValue\":{\"Type\":\"System.String\"}},{\"Description\":\"Hmac hash sizes are 256, 384, 512\",\"MethodName\":\"HashHmacShaInput\",\"Parameters\":[{\"Type\":\"System.String\",\"Name\":\"input\",\"IsRequired\":true},{\"Type\":\"System.String\",\"Name\":\"secretKey\",\"IsRequired\":false},{\"Type\":\"System.Int32\",\"Name\":\"hashSize\",\"DefaultValue\":256,\"IsRequired\":false}],\"ReturnValue\":{\"Type\":\"System.String\"}},{\"Description\":\"Hash input, useSalt = true for passwords. Salt is provided by language when use does not provide. hashAlgorithm: keccak256 | sha256 | bcrypt\",\"MethodName\":\"HashPassword\",\"Parameters\":[{\"Type\":\"System.Object\",\"Name\":\"variable\",\"IsRequired\":true},{\"Type\":\"System.Boolean\",\"Name\":\"returnAsString\",\"DefaultValue\":false,\"IsRequired\":false},{\"Type\":\"System.Boolean\",\"Name\":\"useSalt\",\"DefaultValue\":true,\"IsRequired\":false},{\"Type\":\"System.String\",\"Name\":\"salt\",\"IsRequired\":false},{\"Type\":\"System.String\",\"Name\":\"type\",\"DefaultValue\":\"keccak256\",\"IsRequired\":false}],\"ReturnValue\":{\"Type\":\"System.Object\"}},{\"Description\":\"Hash input. Salt is provided by language when user does not provide. hashAlgorithm: keccak256 | sha256 | bcrypt\",\"MethodName\":\"Hash\",\"Parameters\":[{\"Type\":\"System.Object\",\"Name\":\"variable\",\"IsRequired\":true},{\"Type\":\"System.Nullable`1[System.Boolean]\",\"Name\":\"useSalt\",\"IsRequired\":false},{\"Type\":\"System.String\",\"Name\":\"salt\",\"IsRequired\":false},{\"Type\":\"System.String\",\"Name\":\"type\",\"DefaultValue\":\"keccak256\",\"IsRequired\":false}],\"ReturnValue\":{\"Type\":\"System.Object\"}},{\"Description\":\"Hash input with salt, such as password. hashAlgorithm: keccak256 | sha256 | bcrypt\",\"MethodName\":\"HashInput\",\"Parameters\":[{\"Type\":\"System.Object\",\"Name\":\"variable\",\"IsRequired\":true},{\"Type\":\"System.Boolean\",\"Name\":\"useSalt\",\"DefaultValue\":true,\"IsRequired\":false},{\"Type\":\"System.String\",\"Name\":\"salt\",\"IsRequired\":false},{\"Type\":\"System.String\",\"Name\":\"hashAlgorithm\",\"DefaultValue\":\"keccak256\",\"IsRequired\":false}],\"ReturnValue\":{\"Type\":\"System.String\"}},{\"Description\":\"Hashes Identity string to standard hash\",\"MethodName\":\"HashIdentityString\",\"Parameters\":[{\"Type\":\"System.String\",\"Name\":\"identity\",\"IsRequired\":true}],\"ReturnValue\":{\"Type\":\"System.String\"}},{\"Description\":\"Used to verify hash. hashAlgorithm: keccak256 | sha256 | bcrypt\",\"MethodName\":\"VerifyHashedValues\",\"Parameters\":[{\"Type\":\"System.String\",\"Name\":\"text\",\"IsRequired\":true},{\"Type\":\"System.String\",\"Name\":\"hash\",\"IsRequired\":true},{\"Type\":\"System.String\",\"Name\":\"hashAlgorithm\",\"DefaultValue\":\"keccak256\",\"IsRequired\":false},{\"Type\":\"System.Boolean\",\"Name\":\"useSalt\",\"DefaultValue\":true,\"IsRequired\":false},{\"Type\":\"System.String\",\"Name\":\"salt\",\"IsRequired\":false}],\"ReturnValue\":{\"Type\":\"System.Boolean\"}},{\"Description\":\"Used to verify hash comparing file and a hash. hashAlgorithm: md5 | sha1 | sha256 | sha512. encoding: base64|hex\",\"MethodName\":\"VerifyHashOfFile\",\"Parameters\":[{\"Type\":\"System.String\",\"Name\":\"filePath\",\"IsRequired\":true},{\"Type\":\"System.String\",\"Name\":\"expectedHash\",\"IsRequired\":true},{\"Type\":\"System.String\",\"Name\":\"hashAlgorithm\",\"DefaultValue\":\"sha256\",\"IsRequired\":false},{\"Type\":\"System.String\",\"Name\":\"encoding\",\"DefaultValue\":\"base64\",\"IsRequired\":false}],\"ReturnValue\":{\"Type\":\"System.Boolean\"}},{\"MethodName\":\"GetHashOfFile\",\"Parameters\":[{\"Type\":\"System.String\",\"Name\":\"filePath\",\"IsRequired\":true},{\"Type\":\"System.String\",\"Name\":\"hashAlgorithm\",\"DefaultValue\":\"sha256\",\"IsRequired\":false},{\"Type\":\"System.String\",\"Name\":\"encoding\",\"DefaultValue\":\"base64\",\"IsRequired\":false}],\"ReturnValue\":{\"Type\":\"System.String\"}},{\"MethodName\":\"SetCurrentBearerToken\",\"Parameters\":[{\"Type\":\"System.String\",\"Name\":\"name\",\"IsRequired\":true}]},{\"MethodName\":\"GetBearerSecret\",\"Parameters\":[],\"ReturnValue\":{\"Type\":\"System.String\"}},{\"MethodName\":\"ValidateBearerToken\",\"Parameters\":[{\"Type\":\"System.String\",\"Name\":\"token\",\"IsRequired\":true},{\"Type\":\"System.String\",\"Name\":\"issuer\",\"DefaultValue\":\"PLangRuntime\",\"IsRequired\":false},{\"Type\":\"System.String\",\"Name\":\"audience\",\"DefaultValue\":\"user\",\"IsRequired\":false}],\"ReturnValue\":{\"Type\":\"System.Boolean\"}},{\"Description\":\"Creates a simple token that is valid for x seconds using HMACSHA256. When password is empty, the runtime uses password from settings\",\"MethodName\":\"CreateToken\",\"Parameters\":[{\"Type\":\"System.String\",\"Name\":\"password\",\"IsRequired\":false},{\"Type\":\"System.Int32\",\"Name\":\"validForSeconds\",\"DefaultValue\":600,\"IsRequired\":false},{\"Type\":\"System.String\",\"Name\":\"secretKeyName\",\"IsRequired\":false}],\"ReturnValue\":{\"Type\":\"System.String\"}},{\"Description\":\"Validates token (HMACSHA256) when password is null the runtime uses password from settings\",\"MethodName\":\"ValidateToken\",\"Parameters\":[{\"Type\":\"System.String\",\"Name\":\"token\",\"IsRequired\":true},{\"Type\":\"System.String\",\"Name\":\"password\",\"IsRequired\":false},{\"Type\":\"System.String\",\"Name\":\"secretKeyName\",\"IsRequired\":false}],\"Examples\":[\"validate %token% => token=%token%\"]},{\"MethodName\":\"GenerateBearerToken\",\"Parameters\":[{\"Type\":\"System.String\",\"Name\":\"uniqueString\",\"IsRequired\":true},{\"Type\":\"System.String\",\"Name\":\"issuer\",\"DefaultValue\":\"PLangRuntime\",\"IsRequired\":false},{\"Type\":\"System.String\",\"Name\":\"audience\",\"DefaultValue\":\"user\",\"IsRequired\":false},{\"Type\":\"System.Int32\",\"Name\":\"expireTimeInSeconds\",\"DefaultValue\":604800,\"IsRequired\":false}],\"ReturnValue\":{\"Type\":\"System.String\"}}],\"SupportingObjects\":[]}\n## functions available ends ##\n## defined variables ##\nb64 (type:object), decoded (type:object), \n## defined variables ##\nBearer token names are: Default"
            }
