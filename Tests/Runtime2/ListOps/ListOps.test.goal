Start
- set %myList% = [10, 20, 30]
- add 40 to %myList%
- get count of %myList%, write to %count%
- assert %count% equals 4, "list should have 4 items after add"
- get first item from %myList%, write to %first%
- assert %first% equals 10
- get last item from %myList%, write to %last%
- assert %last% equals 40
- check if %myList% contains 20, write to %has20%
- assert %has20% is true, "list should contain 20"
- join %myList% with separator ", ", write to %joined%
- assert %joined% contains "10"
- assert %joined% contains "40"
- split "a-b-c" by "-", write to %parts%
- get count of %parts%, write to %partsCount%
- assert %partsCount% equals 3
/ get by index
- get item at index 1 from %myList%, write to %second%
- assert %second% equals 20
/ remove
- remove 20 from %myList%
- check if %myList% contains 20, write to %still20%
- assert %still20% is false
/ indexOf
- get index of 30 in %myList%, write to %idx%
- assert %idx% is greater than -1, "indexOf should find the item"
/ sort
- set %unsorted% = [3, 1, 2]
- sort %unsorted%
- get first item from %unsorted%, write to %sortFirst%
- assert %sortFirst% equals 1
/ reverse
- reverse %unsorted%
- get first item from %unsorted%, write to %revFirst%
- assert %revFirst% equals 3
/ unique
- set %dupes% = [1, 2, 2, 3, 3, 3]
- get unique items from %dupes%, write to %uniq%
- get count of %uniq%, write to %uniqCount%
- assert %uniqCount% equals 3
