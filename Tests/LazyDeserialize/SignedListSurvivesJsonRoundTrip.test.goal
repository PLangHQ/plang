- add %signed% to %list%
- save %list% to file 'signed_list_roundtrip.json'
- read file 'signed_list_roundtrip.json', write to %roundtrip%
- verify %roundtrip[0]%, write to %ok%
- assert %ok% equals true
- delete file 'signed_list_roundtrip.json'
