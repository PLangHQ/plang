{
  "name": "FilePathsFromRoot",
  "path": "/FilePathsFromRoot.goal",
  "steps": [
    {
      "index": 0,
      "text": "read testdata.txt, write to %relative%",
      "lineNumber": 2,
      "actions": [
        {
          "module": "file",
          "action": "read",
          "parameters": [
            { "name": "path", "value": "testdata.txt" }
          ]
        },
        {
          "module": "variable",
          "action": "set",
          "parameters": [
            { "name": "Name", "value": "relative" },
            { "name": "Value", "value": "%__data__%" }
          ]
        }
      ]
    },
    {
      "index": 1,
      "text": "read /testdata.txt, write to %absolute%",
      "lineNumber": 3,
      "actions": [
        {
          "module": "file",
          "action": "read",
          "parameters": [
            { "name": "path", "value": "/testdata.txt" }
          ]
        },
        {
          "module": "variable",
          "action": "set",
          "parameters": [
            { "name": "Name", "value": "absolute" },
            { "name": "Value", "value": "%__data__%" }
          ]
        }
      ]
    },
    {
      "index": 2,
      "text": "read sub/subdata.txt, write to %subfolder%",
      "lineNumber": 4,
      "actions": [
        {
          "module": "file",
          "action": "read",
          "parameters": [
            { "name": "path", "value": "sub/subdata.txt" }
          ]
        },
        {
          "module": "variable",
          "action": "set",
          "parameters": [
            { "name": "Name", "value": "subfolder" },
            { "name": "Value", "value": "%__data__%" }
          ]
        }
      ]
    },
    {
      "index": 3,
      "text": "read ./testdata.txt, write to %dotslash%",
      "lineNumber": 5,
      "actions": [
        {
          "module": "file",
          "action": "read",
          "parameters": [
            { "name": "path", "value": "./testdata.txt" }
          ]
        },
        {
          "module": "variable",
          "action": "set",
          "parameters": [
            { "name": "Name", "value": "dotslash" },
            { "name": "Value", "value": "%__data__%" }
          ]
        }
      ]
    }
  ]
}
