{
  "name": "FullPipeline",
  "path": "/FullPipeline.goal",
  "steps": [
    {
      "index": 0,
      "text": "set %greeting% = \"Hello\"",
      "lineNumber": 2,
      "actions": [
        {
          "module": "variable",
          "action": "set",
          "parameters": [
            { "name": "name", "value": "greeting" },
            { "name": "value", "value": "Hello" }
          ],
          "defaults": [
            { "name": "type", "value": "string" }
          ]
        }
      ]
    },
    {
      "index": 1,
      "text": "set %user% = \"World\"",
      "lineNumber": 3,
      "actions": [
        {
          "module": "variable",
          "action": "set",
          "parameters": [
            { "name": "name", "value": "user" },
            { "name": "value", "value": "World" }
          ]
        }
      ]
    },
    {
      "index": 2,
      "text": "write out \"%greeting%, %user%!\"",
      "lineNumber": 4,
      "actions": [
        {
          "module": "output",
          "action": "write",
          "parameters": [
            { "name": "Data", "value": "%greeting%, %user%!" }
          ]
        }
      ]
    },
    {
      "index": 3,
      "text": "set %message% = \"%greeting%, %user%!\"",
      "lineNumber": 5,
      "actions": [
        {
          "module": "variable",
          "action": "set",
          "parameters": [
            { "name": "name", "value": "message" },
            { "name": "value", "value": "%greeting%, %user%!" }
          ]
        }
      ]
    }
  ]
}
